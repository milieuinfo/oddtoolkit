%%{init: {"theme": "base", "themeVariables": {"fontSize": "18px", "primaryColor": "#f0f4ff", "primaryBorderColor": "#4466cc", "lineColor": "#555", "secondaryColor": "#eeffee", "tertiaryColor": "#fff8e1"}}}%%
flowchart TB
    subgraph base["Class Model"]
        direction LR
        CG["ClassGenerator\n(classes, interfaces, enums)"]
    end

    subgraph diag["Diagram Model"]
        direction LR
        DG["DiagramGenerator\n(styles, associations)"]
    end

    subgraph schema["Schema Model"]
        direction LR
        SG["SchemaGenerator\n(tables, columns, relations,\nidentity tables, join tables)"]
    end

    CG --> TS["TypeScript\nGenerator"]
    CG --> DG
    DG --> CD["Class Diagram\nGenerator"]
    DG --> SG
    SG --> SQL["SQL\nGenerator"]
    SG --> ER["ER Diagram\nGenerator"]
    SG --> JV["Java\nGenerator"]

    CG -.-> SHACL["SHACL\nGenerator"]
    CG -.-> FRAME["JSON-LD Frame\nGenerator"]
    CG -.-> BS["Bikeshed\nGenerator"]

    classDef layer fill:#ddeeff,stroke:#4466cc,color:#000
    classDef output fill:#eeffee,stroke:#33aa55,color:#000
    classDef indirect fill:#f5f5f5,stroke:#999,color:#444,stroke-dasharray:4 4
    class CG,DG,SG layer
    class TS,CD,SQL,ER,JV output
    class SHACL,FRAME,BS indirect
