@prefix :       <https://data.riepr.omgeving.vlaanderen.be/ns/riepr#> .
@prefix rdf:    <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs:   <http://www.w3.org/2000/01/rdf-schema#> .
@prefix prov:   <http://www.w3.org/ns/prov#> .
@prefix pplan:  <http://purl.org/net/p-plan#> .
@prefix owl:    <http://www.w3.org/2002/07/owl#> .
@prefix ogc:    <http://www.opengis.net/ont/geosparql#> .
@prefix sosa:   <http://www.w3.org/ns/sosa/> .
@prefix ssn:    <http://www.w3.org/ns/ssn/> .
@prefix ssn-system: <http://www.w3.org/ns/ssn/systems/> .
@prefix hydra:  <http://www.w3.org/ns/hydra/core#> .
@prefix dbo:    <http://dbpedia.org/ontology/> .
@prefix xsd:    <http://www.w3.org/2001/XMLSchema#> .
@prefix org:    <http://www.w3.org/ns/org#> .
@prefix skos:   <http://www.w3.org/2004/02/skos/core#> .
@prefix foaf:   <http://xmlns.com/foaf/0.1/> .
@prefix concept: <https://data.riepr.omgeving.vlaanderen.be/id/concept/> .
@prefix vann:   <http://purl.org/vocab/vann/> .
@prefix dct:    <http://purl.org/dc/terms/> .
@prefix adms: <http://www.w3.org/ns/adms#> .
@prefix locn:   <http://www.w3.org/ns/locn#> .
@prefix qudt:   <http://qudt.org/schema/qudt/> .
@prefix nace:   <http://data.europa.eu/ux2/nace2.1/> .
@prefix dossier: <https://data.vlaanderen.be/ns/dossier#> .
@prefix oa: <http://www.w3.org/ns/oa#> .

# --------------------------------------- #
# Ontology definition
# --------------------------------------- #

<> a owl:Ontology ;
    dct:title "RIE-IEPR Ontologie"@nl ;
    dct:title "RIE-IEPR Ontology"@en ;
    dct:creator "Vlaamse overheid - Departement Omgeving"@nl ;
    dct:creator "Flemish Government - Department of Environment"@en ;
    dct:publisher "Vlaamse overheid - Departement Omgeving"@nl ;
    dct:publisher "Flemish Government - Department of Environment and Spatial Development"@en ;
    dct:description "De RIE-IEPR ontologie definieert een datamodel voor het beschrijven van industriele processen, installaties, emissiepunten, meetpunten, apparaten, observaties, exploitanten en exploitatielocaties binnen het kader van het RIE-IEPR systeem."@nl ;
    dct:description "The RIE-IEPR ontology defines a data model for describing industrial processes, installations, emission points, measurement points, devices, observations, operators and operation locations within the context of the RIE-IEPR system."@en ;
    dct:license <https://data.vlaanderen.be/id/licentie/modellicentie-gratis-hergebruik/v1.0> ;
    dct:issued "2026-04-09"^^xsd:date ;
    dct:modified "2026-04-09"^^xsd:date ;
    owl:versionInfo "1.0.0" ;
    vann:preferredNamespacePrefix "riepr" ;
    vann:preferredNamespaceUri "https://data.riepr.omgeving.vlaanderen.be/ns/riepr#" ;
    rdfs:seeAlso <https://omgeving.vlaanderen.be> ;
    foaf:homepage <https://github.com/milieuinfo/RIE-IEPR> ;
    owl:imports prov: , pplan: , ogc: , sosa: , ssn: , dbo: , org: , skos: , foaf:, qudt:, adms: , locn:, nace:, <http://www.w3.org/ns/sosa/prov> .

# --------------------------------------- #
# Classes
# --------------------------------------- #

:Exploitant a owl:Class ;
    rdfs:label "Exploitant"@nl ;
    rdfs:comment "Een exploitant is een entiteit die een milieuimpact heeft."@nl ;
    hydra:search [ a hydra:IriTemplate ;
        hydra:template "https://data.riepr.omgeving.vlaanderen.be/id/exploitant/{uuid}/{issued}/{created}"^^hydra:Rfc6570Template ;
        hydra:mapping [ hydra:variable "uuid" ; hydra:property :localId ; hydra:required true ] ,
                      [ hydra:variable "issued" ; hydra:property dct:issued ; hydra:required true ] ,
                      [ hydra:variable "created" ; hydra:property dct:created ; hydra:required true ]
    ] ;
    rdfs:subClassOf prov:Agent ;
    rdfs:subClassOf [ a owl:Restriction ;
        rdfs:comment "Een exploitant kan een modificatie datum hebben"@nl ;
        owl:onProperty dct:modified ;
        owl:someValuesFrom xsd:dateTime ;
        owl:minCardinality "0"^^xsd:nonNegativeInteger ;
        owl:maxCardinality "1"^^xsd:nonNegativeInteger
    ] ;
    rdfs:subClassOf [ a owl:Restriction ;
        rdfs:comment "Een exploitant kan een creatie datum hebben"@nl ;
        owl:onProperty dct:created ;
        owl:someValuesFrom xsd:dateTime ;
        owl:minCardinality "0"^^xsd:nonNegativeInteger ;
        owl:maxCardinality "1"^^xsd:nonNegativeInteger
    ] ;
    rdfs:subClassOf [ a owl:Restriction ;
        rdfs:comment "Een exploitant kan een geldigheid start hebben"@nl ;
        owl:onProperty dct:issued ;
        owl:someValuesFrom xsd:date ;
        owl:minCardinality "0"^^xsd:nonNegativeInteger ;
        owl:maxCardinality "1"^^xsd:nonNegativeInteger
    ] ;
    rdfs:subClassOf [ a owl:Restriction ;
        rdfs:comment "Een exploitant kan een geldigheid einde hebben"@nl ;
        owl:onProperty dct:valid ;
        owl:someValuesFrom xsd:date ;
        owl:minCardinality "0"^^xsd:nonNegativeInteger ;
        owl:maxCardinality "1"^^xsd:nonNegativeInteger
    ] ;
    rdfs:subClassOf [ a owl:Restriction ;
        rdfs:comment "Een exploitant kan verbonden zijn aan een enkele aangifte"@nl ;
        owl:onProperty :aangifte ;
        owl:someValuesFrom :Aangifte ;
        owl:minCardinality "0"^^xsd:nonNegativeInteger ;
        owl:maxCardinality "1"^^xsd:nonNegativeInteger
    ] ;
    rdfs:subClassOf [ a owl:Restriction ;
        rdfs:comment "Een exploitant moet een benaming hebben"@nl ;
        owl:onProperty rdfs:label ;
        owl:minCardinality "1"^^xsd:nonNegativeInteger
    ] ;
    rdfs:subClassOf [ a owl:Restriction ;
        # *..* relation with org:memberOf
        rdfs:comment "Een exploitant kan meerdere contactpersonen hebben"@nl ;
        owl:onProperty org:hasMember ;
        owl:someValuesFrom :Contactpersoon ;
        owl:minCardinality "0"^^xsd:nonNegativeInteger
    ] ;
    rdfs:subClassOf [ a owl:Restriction ;
        rdfs:comment "Een exploitant moet een adres hebben"@nl ;
        owl:onProperty locn:address ;
        owl:someValuesFrom locn:Address ;
        owl:minCardinality "1"^^xsd:nonNegativeInteger ;
        owl:maxCardinality "1"^^xsd:nonNegativeInteger
    ] ;
    rdfs:subClassOf [ a owl:Restriction ;
        rdfs:comment "Een exploitant moet een hoofdactiviteit hebben"@nl ;
        owl:onProperty org:classification ;
        owl:minCardinality "0"^^xsd:nonNegativeInteger ;
        owl:maxCardinality "1"^^xsd:nonNegativeInteger
    ] .

:Contactpersoon a owl:Class ;
    rdfs:label "Exploitant Contactpersoon"@nl ;
    rdfs:comment "Een exploitant contactpersoon is een persoon die optreedt als contactpersoon voor een exploitant."@nl ;
    rdfs:subClassOf foaf:Person ;
    hydra:search [ a hydra:IriTemplate ;
        hydra:template "https://data.riepr.omgeving.vlaanderen.be/id/contactpersoon/{uuid}/{issued}/{created}"^^hydra:Rfc6570Template ;
        hydra:mapping [ hydra:variable "uuid" ; hydra:property :localId ; hydra:required true ] ,
                      [ hydra:variable "issued" ; hydra:property dct:issued ; hydra:required true ] ,
                      [ hydra:variable "created" ; hydra:property dct:created ; hydra:required true ]
    ] ;
    rdfs:subClassOf [ a owl:Restriction ;
        rdfs:comment "Een exploitant contactpersoon moet een benaming hebben"@nl ;
        owl:onProperty rdfs:label ;
        owl:minCardinality "1"^^xsd:nonNegativeInteger
    ] ;
    rdfs:subClassOf [ a owl:Restriction ;
        rdfs:comment "Een exploitant contactpersoon kan een e-mailadres hebben"@nl ;
        owl:onProperty foaf:mbox ;
        owl:minCardinality "0"^^xsd:nonNegativeInteger ;
        owl:maxCardinality "1"^^xsd:nonNegativeInteger
    ] ;
    rdfs:subClassOf [ a owl:Restriction ;
        rdfs:comment "Een exploitant contactpersoon kan een telefoonnummer hebben"@nl ;
        owl:onProperty foaf:phone ;
        owl:minCardinality "0"^^xsd:nonNegativeInteger ;
        owl:maxCardinality "1"^^xsd:nonNegativeInteger
    ] ;
    rdfs:subClassOf [ a owl:Restriction ;
        rdfs:comment "Een exploitant contactpersoon moet een functie hebben binnen de organisatie"@nl ;
        owl:onProperty org:hasRole ;
        owl:minCardinality "0"^^xsd:nonNegativeInteger ;
        owl:maxCardinality "1"^^xsd:nonNegativeInteger
    ] ;
    rdfs:subClassOf [ a owl:Restriction ;
        rdfs:comment "Een exploitant contactpersoon kan een modificatie datum hebben"@nl ;
        owl:onProperty dct:modified ;
        owl:someValuesFrom xsd:dateTime ;
        owl:minCardinality "0"^^xsd:nonNegativeInteger ;
        owl:maxCardinality "1"^^xsd:nonNegativeInteger
    ] ;
    rdfs:subClassOf [ a owl:Restriction ;
        rdfs:comment "Een exploitant contactpersoon kan een creatie datum hebben"@nl ;
        owl:onProperty dct:created ;
        owl:someValuesFrom xsd:dateTime ;
        owl:minCardinality "0"^^xsd:nonNegativeInteger ;
        owl:maxCardinality "1"^^xsd:nonNegativeInteger
    ] ;
    rdfs:subClassOf [ a owl:Restriction ;
        rdfs:comment "Een exploitant contactpersoon kan een geldigheid start hebben"@nl ;
        owl:onProperty dct:issued ;
        owl:someValuesFrom xsd:date ;
        owl:minCardinality "0"^^xsd:nonNegativeInteger ;
        owl:maxCardinality "1"^^xsd:nonNegativeInteger
    ] ;
    rdfs:subClassOf [ a owl:Restriction ;
        rdfs:comment "Een exploitant contactpersoon kan een geldigheid einde hebben"@nl ;
        owl:onProperty dct:valid ;
        owl:someValuesFrom xsd:date ;
        owl:minCardinality "0"^^xsd:nonNegativeInteger ;
        owl:maxCardinality "1"^^xsd:nonNegativeInteger
    ] ;
    rdfs:subClassOf [ a owl:Restriction ;
        rdfs:comment "Een exploitant contactpersoon moet een naam hebben"@nl ;
        owl:onProperty foaf:name ;
        owl:minCardinality "1"^^xsd:nonNegativeInteger
    ] ;
    rdfs:subClassOf [ a owl:Restriction ;
        rdfs:comment "Een exploitant contactpersoon kan een opmerking hebben"@nl ;
        owl:onProperty rdfs:comment ;
        owl:minCardinality "0"^^xsd:nonNegativeInteger
    ] ;
    rdfs:subClassOf [ a owl:Restriction ;
        # *..* relation with org:member
        owl:onProperty org:memberOf ;
        owl:someValuesFrom :Exploitant, :Exploitatie ;
        owl:minCardinality "0"^^xsd:nonNegativeInteger
    ] .

:Exploitatielocatie a owl:Class ;
    rdfs:label "Exploitatielocatie"@nl ;
    rdfs:comment "Een exploitatielocatie is een specifieke geografische locatie waar een exploitant zijn processen uitvoert."@nl ;
    hydra:search [ a hydra:IriTemplate ;
        hydra:template "https://data.riepr.omgeving.vlaanderen.be/id/Exploitatielocatie/{localId}/{issued}/{created}"^^hydra:Rfc6570Template ;
        hydra:mapping [ hydra:variable "localId" ; hydra:property :localId ; hydra:required true ] ,
                      [ hydra:variable "issued" ; hydra:property dct:issued ; hydra:required true ] ,
                      [ hydra:variable "created" ; hydra:property dct:created ; hydra:required true ]
    ] ;
    rdfs:subClassOf ogc:Feature, prov:Entity, sosa:Platform ;
    rdfs:subClassOf [ a owl:Restriction ;
        rdfs:comment "Een exploitatielocatie moet een modificatie datum hebben"@nl ;
        owl:onProperty dct:modified ;
        owl:someValuesFrom xsd:dateTime ;
        owl:minCardinality "1"^^xsd:nonNegativeInteger ;
        owl:maxCardinality "1"^^xsd:nonNegativeInteger
    ] ;
    rdfs:subClassOf [ a owl:Restriction ;
        rdfs:comment "Een exploitatielocatie moet een datum hebben waarop het is ingegeven"@nl ;
        owl:onProperty dct:created ;
        owl:someValuesFrom xsd:dateTime ;
        owl:minCardinality "1"^^xsd:nonNegativeInteger ;
        owl:maxCardinality "1"^^xsd:nonNegativeInteger
    ] ;
    rdfs:subClassOf [ a owl:Restriction ;
        rdfs:comment "Een exploitatielocatie moet een benaming hebben"@nl ;
        owl:onProperty rdfs:label ;
        owl:minCardinality "1"^^xsd:nonNegativeInteger
    ] ;
    rdfs:subClassOf [ a owl:Restriction ;
        rdfs:comment "Een exploitatielocatie kan een beschrijving hebben"@nl ;
        owl:onProperty rdfs:comment ;
        owl:minCardinality "0"^^xsd:nonNegativeInteger
    ] ;
    rdfs:subClassOf [ a owl:Restriction ;
        rdfs:comment "Een exploitatielocatie moet een geldigheid start hebben"@nl ;
        owl:onProperty dct:issued ;
        owl:someValuesFrom xsd:date ;
        owl:minCardinality "1"^^xsd:nonNegativeInteger ;
        owl:maxCardinality "1"^^xsd:nonNegativeInteger
    ] ;
    rdfs:subClassOf [ a owl:Restriction ;
        rdfs:comment "Een exploitatielocatie kan een geldigheid einde hebben"@nl ;
        owl:onProperty dct:valid ;
        owl:someValuesFrom xsd:date ;
        owl:minCardinality "0"^^xsd:nonNegativeInteger ;
        owl:maxCardinality "1"^^xsd:nonNegativeInteger
    ] ;
    rdfs:subClassOf [ a owl:Restriction ;
        rdfs:comment "Een exploitatielocatie kan verbonden zijn aan een enkele aangifte"@nl ;
        owl:onProperty :aangifte ;
        owl:someValuesFrom :Aangifte ;
        owl:minCardinality "0"^^xsd:nonNegativeInteger ;
        owl:maxCardinality "1"^^xsd:nonNegativeInteger
    ] ;
    rdfs:subClassOf [ a owl:Restriction ;
        rdfs:comment "Een exploitatielocatie moet gekoppeld zijn aan exact één exploitant"@nl ;
        owl:onProperty prov:wasAttributedTo ;
        owl:someValuesFrom :Exploitant ;
        owl:minCardinality "1"^^xsd:nonNegativeInteger ;
        owl:maxCardinality "1"^^xsd:nonNegativeInteger
    ] ;
    rdfs:subClassOf [ a owl:Restriction ;
        rdfs:comment "Een exploitatielocatie heeft externe identificaties (optioneel)"@nl ;
        owl:onProperty adms:identifier ;
        owl:someValuesFrom adms:Identifier ;
        owl:minCardinality "0"^^xsd:nonNegativeInteger
    ] ;
    rdfs:subClassOf [ a owl:Restriction ;
        rdfs:comment "Een exploitatielocatie kan overeenkomen met één vestiging (VKBO)"@nl ;
        owl:onProperty prov:hadPrimarySource ;
        owl:someValuesFrom org:Site ;
        owl:minCardinality "0"^^xsd:nonNegativeInteger ;
        owl:maxCardinality "1"^^xsd:nonNegativeInteger
    ] ;
    skos:example [ a :Exploitatielocatie ;
        rdfs:label "Cementfabriek Antwerpen"@nl ;
        prov:hadPrimarySource [ a org:Site ;
            rdfs:label "VKBO Vestiging Cementfabriek"@nl
        ]
    ] ;
    rdfs:subClassOf [ a owl:Restriction ;
        rdfs:comment "Een exploitatielocatie kan optioneel beïnvloed zijn door aan een org:Site of ander type"@nl ;
        owl:onProperty prov:wasInfluencedBy ;
        owl:minCardinality "0"^^xsd:nonNegativeInteger ;
        owl:maxCardinality "1"^^xsd:nonNegativeInteger
    ] ;
    rdfs:subClassOf [ a owl:Restriction ;
        rdfs:comment "Een exploitatielocatie kan een revisie zijn van een andere exploitatie locatie (optioneel)"@nl ;
        owl:onProperty prov:wasRevisionOf ;
        owl:someValuesFrom :Exploitatielocatie ;
        owl:minCardinality "0"^^xsd:nonNegativeInteger ;
        owl:maxCardinality "1"^^xsd:nonNegativeInteger
    ] ;
    rdfs:subClassOf [ a owl:Restriction ;
        rdfs:comment "Een exploitatielocatie moet exact 1 geometrie hebben"@nl ;
        owl:onProperty ogc:hasGeometry ;
        owl:minCardinality "1"^^xsd:nonNegativeInteger ;
        owl:maxCardinality "1"^^xsd:nonNegativeInteger
    ] ;
    rdfs:subClassOf [ a owl:Restriction ;
        rdfs:comment "Een exploitatielocatie kan een adres hebben"@nl ;
        owl:onProperty locn:address ;
        owl:someValuesFrom locn:Address ;
        owl:minCardinality "0"^^xsd:nonNegativeInteger ;
        owl:maxCardinality "1"^^xsd:nonNegativeInteger
    ] ;
    rdfs:subClassOf [ a owl:Restriction ;
        # *..* relation with ssn:deployedSystem
        owl:onProperty ssn:inDeployment ;
        owl:someValuesFrom :Exploitatie ;
        owl:minCardinality "0"^^xsd:nonNegativeInteger
    ] .

:Exploitatie a owl:Class ;
    rdfs:label "Exploitatie"@nl ;
    rdfs:comment "Een exploitatie is de uitrol van middelen door een exploitant op een exploitatie locatie leidend tot een milieueffect."@nl ;
    rdfs:subClassOf ssn:Deployment ;
    hydra:search [ a hydra:IriTemplate ;
        hydra:template "https://data.riepr.omgeving.vlaanderen.be/id/exploitatie/{localId}/{issued}/{created}"^^hydra:Rfc6570Template ;
        hydra:mapping [ hydra:variable "localId" ; hydra:property :localId ; hydra:required true ] ,
                      [ hydra:variable "issued" ; hydra:property dct:issued ; hydra:required true ] ,
                      [ hydra:variable "created" ; hydra:property dct:created ; hydra:required true ]
    ] ;
    rdfs:subClassOf [ a owl:Restriction ;
        rdfs:comment "Een exploitatie moet een benaming hebben"@nl ;
        owl:onProperty rdfs:label ;
        owl:minCardinality "1"^^xsd:nonNegativeInteger
    ] ;
    rdfs:subClassOf [ a owl:Restriction ;
        rdfs:comment "Een exploitatie moet een modificatie datum hebben"@nl ;
        owl:onProperty dct:modified ;
        owl:someValuesFrom xsd:dateTime ;
        owl:minCardinality "1"^^xsd:nonNegativeInteger ;
        owl:maxCardinality "1"^^xsd:nonNegativeInteger
    ] ;
    rdfs:subClassOf [ a owl:Restriction ;
        rdfs:comment "Een exploitatie moet een creatie datum hebben"@nl ;
        owl:onProperty dct:created ;
        owl:someValuesFrom xsd:dateTime ;
        owl:minCardinality "1"^^xsd:nonNegativeInteger ;
        owl:maxCardinality "1"^^xsd:nonNegativeInteger
    ] ;
    rdfs:subClassOf [ a owl:Restriction ;
        # *..* relation with ssn:inDeployment
        rdfs:comment "Een exploitatie zet systemen in"@nl ;
        owl:onProperty ssn:deployedSystem ;
        owl:someValuesFrom ssn:System ;
        owl:minCardinality "0"^^xsd:nonNegativeInteger ;
    ] ;
    rdfs:subClassOf [ a owl:Restriction ;
        rdfs:comment "Een exploitatie wordt op een bepaalde exploitatie locatie uitgevoerd"@nl ;
        owl:onProperty ssn:deployedOnPlatform ;
        owl:someValuesFrom :Exploitatielocatie ;
        owl:minCardinality "1"^^xsd:nonNegativeInteger ;
        owl:maxCardinality "1"^^xsd:nonNegativeInteger
    ] ;
    rdfs:subClassOf [ a owl:Restriction ;
        rdfs:comment "Een exploitatie heeft een status"@nl ;
        owl:onProperty adms:status ;
        owl:someValuesFrom adms:Status ;
        owl:minCardinality "1"^^xsd:nonNegativeInteger ;
        owl:maxCardinality "1"^^xsd:nonNegativeInteger
    ] ;
    rdfs:subClassOf [ a owl:Restriction ;
        rdfs:comment "Een exploitatie kan externe identificaties hebben (optioneel)"@nl ;
        owl:onProperty adms:identifier ;
        owl:someValuesFrom adms:Identifier ;
        owl:minCardinality "0"^^xsd:nonNegativeInteger
    ] ;
    rdfs:subClassOf [ a owl:Restriction ;
        rdfs:comment "Een exploitatie moet een geldigheid start hebben"@nl ;
        owl:onProperty dct:issued ;
        owl:someValuesFrom xsd:date ;
        owl:minCardinality "1"^^xsd:nonNegativeInteger ;
        owl:maxCardinality "1"^^xsd:nonNegativeInteger
    ] ;
    rdfs:subClassOf [ a owl:Restriction ;
        rdfs:comment "Een exploitatie kan een geldigheid einde hebben"@nl ;
        owl:onProperty dct:valid ;
        owl:someValuesFrom xsd:date ;
        owl:minCardinality "0"^^xsd:nonNegativeInteger ;
        owl:maxCardinality "1"^^xsd:nonNegativeInteger
    ] ;
    rdfs:subClassOf [ a owl:Restriction ;
        rdfs:comment "Een exploitatie kan verbonden zijn aan een enkele aangifte"@nl ;
        owl:onProperty :aangifte ;
        owl:someValuesFrom :Aangifte ;
        owl:minCardinality "0"^^xsd:nonNegativeInteger ;
        owl:maxCardinality "1"^^xsd:nonNegativeInteger
    ] ;
    rdfs:subClassOf [ a owl:Restriction ;
        rdfs:comment "Een exploitatie implementeert een proces"@nl ;
        owl:onProperty ssn:implements ;
        owl:someValuesFrom :Proces ;
        owl:minCardinality "1"^^xsd:nonNegativeInteger ;
        owl:maxCardinality "1"^^xsd:nonNegativeInteger
    ] ;
    rdfs:subClassOf [ a owl:Restriction ;
        # *..* relation with org:memberOf
        rdfs:comment "Een exploitatie kan meerdere contactpersonen hebben"@nl ;
        owl:onProperty org:hasMember ;
        owl:someValuesFrom :Contactpersoon ;
        owl:minCardinality "0"^^xsd:nonNegativeInteger
    ] .

:Proces a owl:Class ;
    rdfs:label "Proces"@nl ;
    rdfs:comment "Een (milieu)proces is een door de gebruiker in te vullen industrieel proces op een bepaalde locatie bestaande uit meerdere procedurestappen die het proces beschrijven. Een proces kan hiërarchisch opgebouwd zijn als een plan met substappen."@nl ;
    hydra:search [ a hydra:IriTemplate ;
        hydra:template "https://data.riepr.omgeving.vlaanderen.be/id/proces/{localId}/{issued}/{created}"^^hydra:Rfc6570Template ;
        hydra:mapping [ hydra:variable "localId" ; hydra:property :localId ; hydra:required true ] ,
                      [ hydra:variable "issued" ; hydra:property dct:issued ; hydra:required true ] ,
                      [ hydra:variable "created" ; hydra:property dct:created ; hydra:required true ]
    ] ;
    rdfs:subClassOf [ a owl:Restriction ;
        rdfs:comment "Een (exploitatie)proces is verschillend van de exploitatie die het implementeert"@nl ;
        owl:disjointWith :Exploitatie
    ] ;
    skos:example [ a :Proces ;
        rdfs:label "Productie van cement in een fabriek te Antwerpen"@nl ;
        dct:created "2024-01-15T10:00:00"^^xsd:dateTime ;
        sosa:isHostedBy [ a :Exploitatielocatie ;
            rdfs:label "Cementfabriek Antwerpen"@nl
        ]
    ] ;
    skos:example [ a :Proces ;
        rdfs:label "Verwerking van grondstoffen"@nl ;
        dct:type [ a :VerwerkingProcedure ]
    ] ;
    rdfs:subClassOf pplan:Plan, pplan:Step, sosa:Procedure ;
    owl:equivalentClass [ a owl:Class ;
        rdfs:comment "Proces kan een plan op zichzelf zijn (multi step)"@nl ;
        owl:unionOf ( pplan:Step pplan:MultiStep pplan:Plan )
    ] ;
    rdfs:subClassOf [ a owl:Restriction ;
        rdfs:comment "Een proces kan een geldigheid start hebben"@nl ;
        owl:onProperty dct:issued ;
        owl:someValuesFrom xsd:date ;
        owl:minCardinality "0"^^xsd:nonNegativeInteger ;
        owl:maxCardinality "1"^^xsd:nonNegativeInteger
    ] ;
    rdfs:subClassOf [ a owl:Restriction ;
        rdfs:comment "Een proces kan een geldigheid einde hebben"@nl ;
        owl:onProperty dct:valid ;
        owl:someValuesFrom xsd:date ;
        owl:minCardinality "0"^^xsd:nonNegativeInteger ;
        owl:maxCardinality "1"^^xsd:nonNegativeInteger
    ] ;
    rdfs:subClassOf [ a owl:Restriction ;
        rdfs:comment "Een proces kan verbonden zijn aan een enkele aangifte"@nl ;
        owl:onProperty :aangifte ;
        owl:someValuesFrom :Aangifte ;
        owl:minCardinality "0"^^xsd:nonNegativeInteger ;
        owl:maxCardinality "1"^^xsd:nonNegativeInteger
    ] ;
    rdfs:subClassOf [ a owl:Restriction ;
        rdfs:comment "Een proces kan een revisie zijn van een ander proces (optioneel)"@nl ;
        owl:onProperty prov:wasRevisionOf ;
        owl:someValuesFrom :Proces ;
        owl:minCardinality "0"^^xsd:nonNegativeInteger ;
        owl:maxCardinality "1"^^xsd:nonNegativeInteger
    ] ;
    rdfs:subClassOf [ a owl:Restriction ;
        rdfs:comment "Een proces moet een modificatie datum hebben"@nl ;
        owl:onProperty dct:modified ;
        owl:someValuesFrom xsd:dateTime ;
        owl:minCardinality "1"^^xsd:nonNegativeInteger ;
        owl:maxCardinality "1"^^xsd:nonNegativeInteger
    ] ;
    rdfs:subClassOf [ a owl:Restriction ;
        rdfs:comment "Een proces moet een datum hebben waarop het is ingegeven"@nl ;
        owl:onProperty dct:created ;
        owl:someValuesFrom xsd:dateTime ;
        owl:minCardinality "1"^^xsd:nonNegativeInteger ;
        owl:maxCardinality "1"^^xsd:nonNegativeInteger
    ] ;
    rdfs:subClassOf [ a owl:Restriction ;
        rdfs:comment "Een proces moet een benaming hebben"@nl ;
        owl:onProperty rdfs:label ;
        owl:minCardinality "1"^^xsd:nonNegativeInteger
    ] ;
    rdfs:subClassOf [ a owl:Restriction ;
        rdfs:comment "Een proces kan een beschrijving hebben"@nl ;
        owl:onProperty rdfs:comment ;
        owl:minCardinality "0"^^xsd:nonNegativeInteger
    ] ;
    rdfs:subClassOf [ a owl:Restriction ;
        rdfs:comment "Een proces moet een enkele status hebben"@nl ;
        owl:onProperty adms:status ;
        owl:someValuesFrom adms:Status ;
        owl:minCardinality "1"^^xsd:nonNegativeInteger ;
        owl:maxCardinality "1"^^xsd:nonNegativeInteger
    ] ;
    rdfs:subClassOf [ a owl:Restriction ;
        rdfs:comment "Een proces kan zijn afgeleid van een (generieke) procedure (optioneel). Max 1 omdat een proces slechts van 1 procedure afgeleid kan zijn en deze procedure een verzameling van andere procedures zou moeten zijn."@nl ;
        owl:onProperty dct:type ;
        owl:someValuesFrom sosa:Procedure ;
        owl:minCardinality "0"^^xsd:nonNegativeInteger ;
        owl:maxCardinality "1"^^xsd:nonNegativeInteger
    ] ;
    rdfs:subClassOf [ a owl:Restriction ;
        rdfs:comment "Een proces kan optioneel een variable die een systeem representeert gebruiken"@nl ;
        owl:onProperty ssn:implementedBy ;
        owl:someValuesFrom ssn:System ;
        owl:minCardinality "0"^^xsd:nonNegativeInteger ;
        owl:maxCardinality "1"^^xsd:nonNegativeInteger
    ] ;
    rdfs:subClassOf [ a owl:Restriction ;
        # *..* relation with pplan:isInputVarOf
        rdfs:comment "Een proces mag minstens één inputvariabele hebben (stof)"@nl ;
        owl:onProperty pplan:hasInputVar ;
        owl:someValuesFrom pplan:Variable ;
        owl:minCardinality "0"^^xsd:nonNegativeInteger
    ] ;
    rdfs:subClassOf [ a owl:Restriction ;
        rdfs:comment "Een proces mag een of meer andere processen als voorgaande stap hebben."@nl ;
        owl:onProperty pplan:isPrecededBy ;
        owl:someValuesFrom :Proces ;
        owl:minCardinality "0"^^xsd:nonNegativeInteger
    ] ;
    rdfs:subClassOf [ a owl:Restriction ;
        # *..* relation with pplan:isOutputVarOf
        rdfs:comment "Een proces mag minstens één outputvariabele hebben (stof)"@nl ;
        owl:onProperty pplan:hasOutputVar ;
        owl:someValuesFrom pplan:Variable ;
        owl:minCardinality "0"^^xsd:nonNegativeInteger
    ] ;
    rdfs:subClassOf [ a owl:Restriction ;
        rdfs:comment "Een proces kan deel uitmaken van een ander proces"@nl ;
        owl:onProperty pplan:isStepOfPlan ;
        owl:someValuesFrom :Proces ;
        owl:minCardinality "0"^^xsd:nonNegativeInteger ;
        owl:maxCardinality "1"^^xsd:nonNegativeInteger
    ] ;
    rdfs:subClassOf [ a owl:Restriction ;
        rdfs:comment "Een proces kan meerdere rubrieken hebben"@nl ;
        owl:onProperty :rubriek ;
        owl:someValuesFrom :Rubriek ;
        owl:minCardinality "0"^^xsd:nonNegativeInteger ;
    ] ;
    rdf:subClassOf [ a owl:Restriction ;
        # *..* relation with pplan:isStepOfPlan
        owl:onProperty pplan:hasStep ;
        owl:someValuesFrom :Proces ;
        owl:minCardinality "0"^^xsd:nonNegativeInteger
    ] ;
    rdfs:subClassOf [ a owl:Restriction ;
        # *..* relation with ssn:implements
        owl:onProperty ssn:implementedBy ;
        owl:someValuesFrom :Installatie ;
        owl:minCardinality "0"^^xsd:nonNegativeInteger ;
    ] .

:ProcesVariabele a owl:Class ;
    rdfs:label "Proces variabele"@nl ;
    rdfs:comment "Een proces variabele is een variabel gegeven die als input of output van een proces dient."@nl ;
    skos:example [ a :ProcesVariabele ;
        rdfs:label "Meel"@nl ;
        dct:type [ a prov:Entity ;
            rdfs:label "Stof"@nl
        ] ;
    ] ;
    hydra:search [ a hydra:IriTemplate ;
        hydra:template "https://data.riepr.omgeving.vlaanderen.be/id/procesvariabele/{uuid}"^^hydra:Rfc6570Template ;
        hydra:mapping [ hydra:variable "uuid" ; hydra:property :localId ; hydra:required true ]
    ] ;
    rdfs:subClassOf pplan:Variable ;
    rdfs:subClassOf [ a owl:Restriction ;
        rdfs:comment "Een proces variabele kan een benaming hebben"@nl ;
        owl:onProperty rdfs:label ;
        owl:minCardinality "0"^^xsd:nonNegativeInteger
    ] ;
    rdfs:subClassOf [ a owl:Restriction ;
        rdfs:comment "Een proces variabele kan een typering hebben via dct:type"@nl ;
        owl:onProperty dct:type ;
        owl:minCardinality "0"^^xsd:nonNegativeInteger ;
        owl:maxCardinality "1"^^xsd:nonNegativeInteger
    ] ;
    rdfs:subClassOf [ a owl:Restriction ;
        rdfs:comment "Een proces variabele kan een eenheid hebben"@nl ;
        owl:onProperty qudt:hasUnit ;
        owl:minCardinality "0"^^xsd:nonNegativeInteger ;
        owl:maxCardinality "1"^^xsd:nonNegativeInteger
    ] ;
    rdfs:subClassOf [ a owl:Restriction ;
        rdfs:comment "Een proces variabele kan een waarde hebben"@nl ;
        owl:onProperty qudt:numericValue ;
        owl:minCardinality "0"^^xsd:nonNegativeInteger ;
        owl:maxCardinality "1"^^xsd:nonNegativeInteger
    ] ;
    rdfs:subClassOf [ a owl:Restriction ;
        # *..* relation with pplan:hasInputVar
        owl:onProperty pplan:isInputVarOf ;
        owl:someValuesFrom :Proces ;
        owl:minCardinality "0"^^xsd:nonNegativeInteger
    ] ;
    rdfs:subClassOf [ a owl:Restriction ;
        # *..* relation with pplan:hasOutputVar
        owl:onProperty pplan:isOutputVarOf ;
        owl:someValuesFrom :Proces ;
        owl:minCardinality "0"^^xsd:nonNegativeInteger
    ] .

:Installatie a owl:Class ;
    rdfs:label "Installatie"@nl ;
    rdfs:comment "Een installatie is infrastructuur of een verzameling van infrastructuur op een bepaalde locatie die een specifieke functie vervult."@nl ;
    skos:example [ a :Installatie ;
        rdfs:label "Cementfabriek Antwerpen Installatie 1"@nl ;
        dct:created "2020-01-01T00:00:00"^^xsd:dateTime ;
        dct:issued "2020-01-01"^^xsd:date ;
        dct:valid "2030-12-31"^^xsd:date ;
        adms:status :in_gebruik ;
        sosa:isHostedBy [ a :Exploitatielocatie ;
            rdfs:label "Cementfabriek Antwerpen"@nl
        ]
    ] ;
    hydra:search [ a hydra:IriTemplate ;
        hydra:template "https://data.riepr.omgeving.vlaanderen.be/id/installatie/{uuid}/{issued}/{created}"^^hydra:Rfc6570Template ;
        hydra:mapping [ hydra:variable "uuid" ; hydra:property :localId ; hydra:required true ] ,
                      [ hydra:variable "issued" ; hydra:property dct:issued ; hydra:required true ] ,
                      [ hydra:variable "created" ; hydra:property dct:created ; hydra:required true ]
    ] ;
    rdfs:subClassOf ssn:System, ogc:SpatialObject ;
    rdfs:subClassOf [ a owl:Restriction ;
        rdfs:comment "Een installatie heeft externe identificaties (optioneel)"@nl ;
        owl:onProperty adms:identifier ;
        owl:someValuesFrom adms:Identifier ;
        owl:minCardinality "0"^^xsd:nonNegativeInteger
    ] ;
    rdfs:subClassOf [ a owl:Restriction ;
        # *..* relation with the inverse of ssn:hasSubSystem
        rdfs:comment "Een installatie kan meerdere objecten bevatten."@nl ;
        owl:onProperty ssn:hasSubSystem ;
        owl:someValuesFrom ssn:System ;
        owl:minCardinality "0"^^xsd:nonNegativeInteger
    ] ;
    rdfs:subClassOf [ a owl:Restriction ;
        rdfs:comment "Een installatie moet een benaming hebben"@nl ;
        owl:onProperty rdfs:label ;
        owl:minCardinality "1"^^xsd:nonNegativeInteger
    ] ;
    rdfs:subClassOf [ a owl:Restriction ;
        rdfs:comment "Een installatie kan een beschrijving hebben"@nl ;
        owl:onProperty rdfs:comment ;
        owl:minCardinality "0"^^xsd:nonNegativeInteger
    ] ;
    rdfs:subClassOf [ a owl:Restriction ;
        rdfs:comment "Een installatie moet een modificatie datum hebben"@nl ;
        owl:onProperty dct:modified ;
        owl:someValuesFrom xsd:dateTime ;
        owl:minCardinality "1"^^xsd:nonNegativeInteger ;
        owl:maxCardinality "1"^^xsd:nonNegativeInteger
    ] ;
    rdfs:subClassOf [ a owl:Restriction ;
        rdfs:comment "Een installatie moet een creatie datum hebben"@nl ;
        owl:onProperty dct:created ;
        owl:someValuesFrom xsd:dateTime ;
        owl:minCardinality "1"^^xsd:nonNegativeInteger ;
        owl:maxCardinality "1"^^xsd:nonNegativeInteger
    ] ;
    rdfs:subClassOf [ a owl:Restriction ;
        rdfs:comment "Een installatie kan een referentie hebben naar een aangifte."@nl ;
        owl:onProperty :ingediend ;
    ] ;
    rdfs:subClassOf [ a owl:Restriction ;
        rdfs:comment "Een installatie moet een geldigheid start hebben"@nl ;
        owl:onProperty dct:issued ;
        owl:someValuesFrom xsd:date ;
        owl:minCardinality "1"^^xsd:nonNegativeInteger ;
        owl:maxCardinality "1"^^xsd:nonNegativeInteger
    ] ;
    rdfs:subClassOf [ a owl:Restriction ;
        rdfs:comment "Een installatie kan een geldigheid einde hebben"@nl ;
        owl:onProperty dct:valid ;
        owl:someValuesFrom xsd:date ;
        owl:minCardinality "0"^^xsd:nonNegativeInteger ;
        owl:maxCardinality "1"^^xsd:nonNegativeInteger
    ] ;
    rdfs:subClassOf [ a owl:Restriction ;
        rdfs:comment "Een installatie kan verbonden zijn aan een enkele aangifte"@nl ;
        owl:onProperty :aangifte ;
        owl:someValuesFrom :Aangifte ;
        owl:minCardinality "0"^^xsd:nonNegativeInteger ;
        owl:maxCardinality "1"^^xsd:nonNegativeInteger
    ] ;
    rdfs:subClassOf [ a owl:Restriction ;
        rdfs:comment "Een installatie moet een enkele status hebben"@nl ;
        owl:onProperty adms:status ;
        owl:someValuesFrom adms:Status ;
        owl:minCardinality "1"^^xsd:nonNegativeInteger ;
        owl:maxCardinality "1"^^xsd:nonNegativeInteger
    ] ;
    rdfs:subClassOf [ a owl:Restriction ;
        rdfs:comment "Een installatie kan een revisie zijn van een andere systemen (optioneel)"@nl ;
        owl:onProperty prov:wasRevisionOf ;
        owl:someValuesFrom ssn:System ;
        owl:minCardinality "0"^^xsd:nonNegativeInteger ;
        owl:maxCardinality "1"^^xsd:nonNegativeInteger
    ] ;
    rdfs:subClassOf [ a owl:Restriction ;
        # *..* relation with ssn:deployedSystem
        owl:onProperty ssn:hasDeployment ;
        owl:someValuesFrom :Exploitatie ;
        owl:minCardinality "0"^^xsd:nonNegativeInteger
    ] ;
    rdfs:subClassOf [ a owl:Restriction ;
        # *..* relation with ssn:hasSubSystem
        owl:onProperty [ a owl:ObjectProperty ;
            owl:inverseOf ssn:hasSubSystem
        ] ;
        owl:someValuesFrom ssn:System ;
        owl:minCardinality "0"^^xsd:nonNegativeInteger
    ] ;
    rdfs:subClassOf [ a owl:Restriction ;
        rdfs:comment "Een installatie mag max 1 geometrie hebben"@nl ;
        owl:onProperty ogc:hasGeometry ;
        owl:minCardinality "0"^^xsd:nonNegativeInteger ;
        owl:maxCardinality "1"^^xsd:nonNegativeInteger
    ] ;
    rdfs:subClassOf [ a owl:Restriction ;
        rdfs:comment "Een installatie kan een typering hebben via dct:type"@nl ;
        owl:onProperty dct:type ;
        owl:minCardinality "0"^^xsd:nonNegativeInteger ;
        owl:maxCardinality "1"^^xsd:nonNegativeInteger
    ] ;
    ## ----- Installatie restricties ------
    rdfs:subClassOf [ a owl:Restriction ;
        rdfs:comment "Een installatie kan meerdere eigenschappen hebben"@nl ;
        owl:onProperty ssn:hasProperty ;
        owl:someValuesFrom :SysteemEigenschap ;
        owl:minCardinality "0"^^xsd:nonNegativeInteger
    ] .

:Emissiepunt a owl:Class ;
    rdfs:label "Emissiepunt"@nl ;
    rdfs:comment "Een emissiepunt is een specifiek punt waar stoffen de installatie verlaten en in de omgeving worden uitgestoten."@nl ;
    skos:example [ a :Emissiepunt ;
        rdfs:label "Schouw 1 Cementfabriek Antwerpen"@nl ;
        dct:issued "2020-01-01"^^xsd:date ;
        dct:valid "2030-12-31"^^xsd:date ;
        sosa:isHostedBy [ a :Installatie ;
            rdfs:label "Cementfabriek Antwerpen Installatie 1"@nl
        ] ;
        ogc:hasGeometry [ a ogc:Geometry ;
            ogc:asWKT "POINT(4.4025 51.2194)"^^ogc:wktLiteral
        ]
    ] ;
        ## ----- Systeem restricties ------
    rdfs:subClassOf ssn:System, ogc:SpatialObject ;
    rdfs:subClassOf [ a owl:Restriction ;
        rdfs:comment "Een emissiepunt heeft externe identificaties (optioneel)"@nl ;
        owl:onProperty adms:identifier ;
        owl:someValuesFrom adms:Identifier ;
        owl:minCardinality "0"^^xsd:nonNegativeInteger
    ] ;
    rdfs:subClassOf [ a owl:Restriction ;
        # *..* relation with the inverse of ssn:hasSubSystem
        rdfs:comment "Een emissiepunt kan meerdere objecten bevatten."@nl ;
        owl:onProperty ssn:hasSubSystem ;
        owl:someValuesFrom ssn:System ;
        owl:minCardinality "0"^^xsd:nonNegativeInteger
    ] ;
    rdfs:subClassOf [ a owl:Restriction ;
        rdfs:comment "Een emissiepunt moet een benaming hebben"@nl ;
        owl:onProperty rdfs:label ;
        owl:minCardinality "1"^^xsd:nonNegativeInteger
    ] ;
    rdfs:subClassOf [ a owl:Restriction ;
        rdfs:comment "Een emissiepunt moet een modificatie datum hebben"@nl ;
        owl:onProperty dct:modified ;
        owl:someValuesFrom xsd:dateTime ;
        owl:minCardinality "1"^^xsd:nonNegativeInteger ;
        owl:maxCardinality "1"^^xsd:nonNegativeInteger
    ] ;
    rdfs:subClassOf [ a owl:Restriction ;
        rdfs:comment "Een emissiepunt moet een creatie datum hebben"@nl ;
        owl:onProperty dct:created ;
        owl:someValuesFrom xsd:dateTime ;
        owl:minCardinality "1"^^xsd:nonNegativeInteger ;
        owl:maxCardinality "1"^^xsd:nonNegativeInteger
    ] ;
    rdfs:subClassOf [ a owl:Restriction ;
        rdfs:comment "Een emissiepunt moet een geldigheid start hebben"@nl ;
        owl:onProperty dct:issued ;
        owl:someValuesFrom xsd:date ;
        owl:minCardinality "1"^^xsd:nonNegativeInteger ;
        owl:maxCardinality "1"^^xsd:nonNegativeInteger
    ] ;
    rdfs:subClassOf [ a owl:Restriction ;
        rdfs:comment "Een emissiepunt kan een geldigheid einde hebben"@nl ;
        owl:onProperty dct:valid ;
        owl:someValuesFrom xsd:date ;
        owl:minCardinality "0"^^xsd:nonNegativeInteger ;
        owl:maxCardinality "1"^^xsd:nonNegativeInteger
    ] ;
    rdfs:subClassOf [ a owl:Restriction ;
        rdfs:comment "Een emissiepunt kan verbonden zijn aan een enkele aangifte"@nl ;
        owl:onProperty :aangifte ;
        owl:someValuesFrom :Aangifte ;
        owl:minCardinality "0"^^xsd:nonNegativeInteger ;
        owl:maxCardinality "1"^^xsd:nonNegativeInteger
    ] ;
    rdfs:subClassOf [ a owl:Restriction ;
        rdfs:comment "Een emissiepunt moet een enkele status hebben"@nl ;
        owl:onProperty adms:status ;
        owl:someValuesFrom adms:Status ;
        owl:minCardinality "1"^^xsd:nonNegativeInteger ;
        owl:maxCardinality "1"^^xsd:nonNegativeInteger
    ] ;
    rdfs:subClassOf [ a owl:Restriction ;
        rdfs:comment "Een emissiepunt kan een revisie zijn van een andere systemen (optioneel)"@nl ;
        owl:onProperty prov:wasRevisionOf ;
        owl:someValuesFrom ssn:System ;
        owl:minCardinality "0"^^xsd:nonNegativeInteger ;
        owl:maxCardinality "1"^^xsd:nonNegativeInteger
    ] ;
    rdfs:subClassOf [ a owl:Restriction ;
        # *..* relation with ssn:deployedSystem
        owl:onProperty ssn:hasDeployment ;
        owl:someValuesFrom :Exploitatie ;
        owl:minCardinality "0"^^xsd:nonNegativeInteger
    ] ;
    rdfs:subClassOf [ a owl:Restriction ;
        # *..* relation with ssn:hasSubSystem
        owl:onProperty [ a owl:ObjectProperty ;
            owl:inverseOf ssn:hasSubSystem
        ] ;
        owl:someValuesFrom ssn:System ;
        owl:minCardinality "0"^^xsd:nonNegativeInteger
    ] ;
    rdfs:subClassOf [ a owl:Restriction ;
        rdfs:comment "Een emissiepunt mag max 1 geometrie hebben"@nl ;
        owl:onProperty ogc:hasGeometry ;
        owl:minCardinality "0"^^xsd:nonNegativeInteger ;
        owl:maxCardinality "1"^^xsd:nonNegativeInteger
    ] ;
    rdfs:subClassOf [ a owl:Restriction ;
        rdfs:comment "Een emissiepunt kan een typering hebben via dct:type"@nl ;
        owl:onProperty dct:type ;
        owl:minCardinality "0"^^xsd:nonNegativeInteger ;
        owl:maxCardinality "1"^^xsd:nonNegativeInteger
    ] ;
    rdfs:subClassOf [ a owl:Restriction ;
        rdfs:comment "Een emissiepunt is verschillend van een onttrekkingspunt (disjoint)"@nl ;
        owl:disjointWith :Onttrekkingspunt
    ] ;
    hydra:search [ a hydra:IriTemplate ;
        hydra:template "https://data.riepr.omgeving.vlaanderen.be/id/emissiepunt/{uuid}/{issued}/{created}"^^hydra:Rfc6570Template ;
        hydra:mapping [ hydra:variable "uuid" ; hydra:property :localId ; hydra:required true ] ,
                      [ hydra:variable "issued" ; hydra:property dct:issued ; hydra:required true ] ,
                      [ hydra:variable "created" ; hydra:property dct:created ; hydra:required true ]
    ] ;
    rdfs:subClassOf [ a owl:Restriction ;
        rdfs:comment "Een emissiepunt kan meerdere eigenschappen hebben"@nl ;
        owl:onProperty ssn:hasProperty ;
        owl:someValuesFrom :SysteemEigenschap ;
        owl:minCardinality "0"^^xsd:nonNegativeInteger
    ] .

:SysteemEigenschap a owl:Class ;
    rdfs:label "Systeem Eigenschap"@nl ;
    rdfs:comment "Een systeem eigenschap is een specifieke eigenschap van een systeem, zoals de hoogte van de schouw."@nl ;
    rdfs:subClassOf ssn:Property ;
    rdfs:subClassOf [ a owl:Restriction ;
        rdfs:comment "Een systeem eigenschap moet een typering hebben"@nl ;
        owl:onProperty dct:type ;
        owl:minCardinality "1"^^xsd:nonNegativeInteger ;
        owl:maxCardinality "1"^^xsd:nonNegativeInteger
    ] ;
    rdfs:subClassOf [ a owl:Restriction ;
        rdfs:comment "Een systeem eigenschap moet een datatype hebben"@nl ;
        owl:onProperty rdfs:range ;
        owl:someValuesFrom rdfs:Datatype ;
        owl:minCardinality "1"^^xsd:nonNegativeInteger ;
        owl:maxCardinality "1"^^xsd:nonNegativeInteger
    ] ;
    rdfs:subClassOf [ a owl:Restriction ;
        rdfs:comment "Een systeem eigenschap kan een waarde hebben"@nl ;
        owl:onProperty rdfs:value ;
        owl:someValuesFrom rdfs:Literal ;
        owl:minCardinality "0"^^xsd:nonNegativeInteger ;
        owl:maxCardinality "1"^^xsd:nonNegativeInteger
    ] ;
    rdfs:subClassOf [ a owl:Restriction ;
        rdfs:comment "Een systeem eigenschap kan een eenheid hebben"@nl ;
        owl:onProperty qudt:hasUnit ;
        owl:minCardinality "0"^^xsd:nonNegativeInteger ;
        owl:maxCardinality "1"^^xsd:nonNegativeInteger
    ] ;
    rdfs:subClassOf [ a owl:Restriction ;
        rdfs:comment "Een systeem eigenschap kan een referentie naar een parameter hebben"@nl ;
        owl:onProperty :parameter ;
        owl:someValuesFrom rdfs:Literal ;
        owl:minCardinality "0"^^xsd:nonNegativeInteger ;
        owl:maxCardinality "1"^^xsd:nonNegativeInteger
    ] .

:Onttrekkingspunt a owl:Class ;
    rdfs:label "Onttrekkingspunt"@nl ;
    rdfs:comment "Een onttrekkingspunt is een punt waar grondstoffen worden gewonnen of bemonsterd (onttrekking)."@nl ;
    skos:example [ a :Onttrekkingspunt ;
        rdfs:label "Onttrekking 1"@nl
    ] ;
    hydra:search [ a hydra:IriTemplate ;
        hydra:template "https://data.riepr.omgeving.vlaanderen.be/id/onttrekkingspunt/{uuid}/{issued}/{created}"^^hydra:Rfc6570Template ;
        hydra:mapping [ hydra:variable "uuid" ; hydra:property :localId ; hydra:required true ] ,
                      [ hydra:variable "issued" ; hydra:property dct:issued ; hydra:required true ] ,
                      [ hydra:variable "created" ; hydra:property dct:created ; hydra:required true ]
    ] ;
    rdfs:subClassOf ssn:System, ogc:SpatialObject ;
    rdfs:subClassOf [ a owl:Restriction ;
        rdfs:comment "Een onttrekkingspunt heeft externe identificaties (optioneel)"@nl ;
        owl:onProperty adms:identifier ;
        owl:someValuesFrom adms:Identifier ;
        owl:minCardinality "0"^^xsd:nonNegativeInteger
    ] ;
    rdfs:subClassOf [ a owl:Restriction ;
        rdfs:comment "Een onttrekkingspunt moet een benaming hebben"@nl ;
        owl:onProperty rdfs:label ;
        owl:minCardinality "1"^^xsd:nonNegativeInteger
    ] ;
    rdfs:subClassOf [ a owl:Restriction ;
        rdfs:comment "Een onttrekkingspunt moet een modificatie datum hebben"@nl ;
        owl:onProperty dct:modified ;
        owl:someValuesFrom xsd:dateTime ;
        owl:minCardinality "1"^^xsd:nonNegativeInteger ;
        owl:maxCardinality "1"^^xsd:nonNegativeInteger
    ] ;
    rdfs:subClassOf [ a owl:Restriction ;
        rdfs:comment "Een onttrekkingspunt moet een creatie datum hebben"@nl ;
        owl:onProperty dct:created ;
        owl:someValuesFrom xsd:dateTime ;
        owl:minCardinality "1"^^xsd:nonNegativeInteger ;
        owl:maxCardinality "1"^^xsd:nonNegativeInteger
    ] ;
    rdfs:subClassOf [ a owl:Restriction ;
        rdfs:comment "Een onttrekkingspunt moet een geldigheid start hebben"@nl ;
        owl:onProperty dct:issued ;
        owl:someValuesFrom xsd:date ;
        owl:minCardinality "1"^^xsd:nonNegativeInteger ;
        owl:maxCardinality "1"^^xsd:nonNegativeInteger
    ] ;
    rdfs:subClassOf [ a owl:Restriction ;
        rdfs:comment "Een onttrekkingspunt kan een geldigheid einde hebben"@nl ;
        owl:onProperty dct:valid ;
        owl:someValuesFrom xsd:date ;
        owl:minCardinality "0"^^xsd:nonNegativeInteger ;
        owl:maxCardinality "1"^^xsd:nonNegativeInteger
    ] ;
    rdfs:subClassOf [ a owl:Restriction ;
        rdfs:comment "Een onttrekkingspunt kan verbonden zijn aan een enkele aangifte"@nl ;
        owl:onProperty :aangifte ;
        owl:someValuesFrom :Aangifte ;
        owl:minCardinality "0"^^xsd:nonNegativeInteger ;
        owl:maxCardinality "1"^^xsd:nonNegativeInteger
    ] ;
    rdfs:subClassOf [ a owl:Restriction ;
        rdfs:comment "Een onttrekkingspunt moet een enkele status hebben"@nl ;
        owl:onProperty adms:status ;
        owl:someValuesFrom adms:Status ;
        owl:minCardinality "1"^^xsd:nonNegativeInteger ;
        owl:maxCardinality "1"^^xsd:nonNegativeInteger
    ] ;
    rdfs:subClassOf [ a owl:Restriction ;
        rdfs:comment "Een onttrekkingspunt kan een revisie zijn van een andere systemen (optioneel)"@nl ;
        owl:onProperty prov:wasRevisionOf ;
        owl:someValuesFrom ssn:System ;
        owl:minCardinality "0"^^xsd:nonNegativeInteger ;
        owl:maxCardinality "1"^^xsd:nonNegativeInteger
    ] ;
    rdfs:subClassOf [ a owl:Restriction ;
        # *..* relation with ssn:deployedSystem
        owl:onProperty ssn:hasDeployment ;
        owl:someValuesFrom :Exploitatie ;
        owl:minCardinality "0"^^xsd:nonNegativeInteger
    ] ;
    rdfs:subClassOf [ a owl:Restriction ;
        # *..* relation with ssn:hasSubSystem
        owl:onProperty [ a owl:ObjectProperty ;
            owl:inverseOf ssn:hasSubSystem
        ] ;
        owl:someValuesFrom ssn:System ;
        owl:minCardinality "0"^^xsd:nonNegativeInteger
    ] ;
    rdfs:subClassOf [ a owl:Restriction ;
        rdfs:comment "Een systeem mag max 1 geometrie hebben"@nl ;
        owl:onProperty ogc:hasGeometry ;
        owl:minCardinality "0"^^xsd:nonNegativeInteger ;
        owl:maxCardinality "1"^^xsd:nonNegativeInteger
    ] ;
    rdfs:subClassOf [ a owl:Restriction ;
        rdfs:comment "Een systeem kan een typering hebben via dct:type"@nl ;
        owl:onProperty dct:type ;
        owl:minCardinality "0"^^xsd:nonNegativeInteger ;
        owl:maxCardinality "1"^^xsd:nonNegativeInteger
    ] ;
    ## ----- Onttrekkingspunt restricties ------
    rdfs:subClassOf [ a owl:Restriction ;
        rdfs:comment "Een onttrekkingspunt is verschillend van een emissiepunt (disjoint)"@nl ;
        owl:disjointWith :Emissiepunt
    ] ;
    rdfs:subClassOf [ a owl:Restriction ;
        rdfs:comment "Een onttrekkingspunt kan een diepte hebben"@nl ;
        owl:onProperty dbo:depth ;
        owl:minCardinality "0"^^xsd:nonNegativeInteger ;
        owl:maxCardinality "1"^^xsd:nonNegativeInteger
    ] ;
    rdfs:subClassOf [ a owl:Restriction ;
        # *..* relation with the inverse of ssn:hasSubSystem
        rdfs:comment "Een onttrekkingspunt kan filters hebben"@nl ;
        owl:onProperty ssn:hasSubSystem ;
        owl:someValuesFrom :Filter ;
        owl:minCardinality "0"^^xsd:nonNegativeInteger
    ] ;
    rdfs:subClassOf [ a owl:Restriction ;
        rdfs:comment "Een onttrekkingspunt kan meerdere eigenschappen hebben"@nl ;
        owl:onProperty ssn:hasProperty ;
        owl:someValuesFrom :SysteemEigenschap ;
        owl:minCardinality "0"^^xsd:nonNegativeInteger
    ] .

:AbstractEmissiepunt a owl:Class ;
    rdfs:label "Abstract Emissiepunt"@nl ;
    rdfs:comment "Een abstract emissiepunt is een conceptueel emissiepunt dat niet noodzakelijk een vaste locatie heeft, maar wel een functionele rol vervult in het proces."@nl ;
    skos:example [ a :AbstractEmissiepunt ;
        rdfs:label "Gebouw uitstootpunt"@nl ;
        dct:issued "2020-01-01"^^xsd:date ;
        dct:valid "2030-12-31"^^xsd:date ;
        sosa:isHostedBy [ a :Exploitatielocatie ;
            rdfs:label "Cementfabriek Antwerpen"@nl
        ]
    ] ;
    rdfs:subClassOf :Emissiepunt .

:Meetpunt a owl:Class ;
    rdfs:label "Meetpunt"@nl ;
    rdfs:comment "Een meetpunt is een specifiek punt waar metingen worden uitgevoerd om de kwaliteit van de uitstoot of de omgeving te controleren."@nl ;
    hydra:search [ a hydra:IriTemplate ;
        hydra:template "https://data.riepr.omgeving.vlaanderen.be/id/meetpunt/{uuid}/{issued}/{created}"^^hydra:Rfc6570Template ;
        hydra:mapping [ hydra:variable "uuid" ; hydra:property :localId ; hydra:required true ] ,
                      [ hydra:variable "issued" ; hydra:property dct:issued ; hydra:required true ] ,
                      [ hydra:variable "created" ; hydra:property dct:created ; hydra:required true ]
    ] ;
    skos:example [ a :Meetpunt ;
        rdfs:label "Meetpunt Luchtkwaliteit Schouw 1"@nl ;
        dct:created "2020-01-01T00:00:00"^^xsd:dateTime ;
        dct:issued "2020-01-01"^^xsd:date ;
        dct:valid "2030-12-31"^^xsd:date ;
        ogc:hasGeometry [ a ogc:Geometry ;
            ogc:asWKT "POINT(4.4026 51.2195)"^^ogc:wktLiteral
        ]
    ] ;
    rdfs:subClassOf ssn:System, ogc:SpatialObject ;
    rdfs:subClassOf [ a owl:Restriction ;
        rdfs:comment "Een meetpunt heeft externe identificaties (optioneel)"@nl ;
        owl:onProperty adms:identifier ;
        owl:someValuesFrom adms:Identifier ;
        owl:minCardinality "0"^^xsd:nonNegativeInteger
    ] ;
    rdfs:subClassOf [ a owl:Restriction ;
        rdfs:comment "Een meetpunt moet een benaming hebben"@nl ;
        owl:onProperty rdfs:label ;
        owl:minCardinality "1"^^xsd:nonNegativeInteger
    ] ;
    rdfs:subClassOf [ a owl:Restriction ;
        rdfs:comment "Een meetpunt moet een modificatie datum hebben"@nl ;
        owl:onProperty dct:modified ;
        owl:someValuesFrom xsd:dateTime ;
        owl:minCardinality "1"^^xsd:nonNegativeInteger ;
        owl:maxCardinality "1"^^xsd:nonNegativeInteger
    ] ;
    rdfs:subClassOf [ a owl:Restriction ;
        rdfs:comment "Een meetpunt moet een creatie datum hebben"@nl ;
        owl:onProperty dct:created ;
        owl:someValuesFrom xsd:dateTime ;
        owl:minCardinality "1"^^xsd:nonNegativeInteger ;
        owl:maxCardinality "1"^^xsd:nonNegativeInteger
    ] ;
    rdfs:subClassOf [ a owl:Restriction ;
        rdfs:comment "Een meetpunt moet een geldigheid start hebben"@nl ;
        owl:onProperty dct:issued ;
        owl:someValuesFrom xsd:date ;
        owl:minCardinality "1"^^xsd:nonNegativeInteger ;
        owl:maxCardinality "1"^^xsd:nonNegativeInteger
    ] ;
    rdfs:subClassOf [ a owl:Restriction ;
        rdfs:comment "Een meetpunt kan een geldigheid einde hebben"@nl ;
        owl:onProperty dct:valid ;
        owl:someValuesFrom xsd:date ;
        owl:minCardinality "0"^^xsd:nonNegativeInteger ;
        owl:maxCardinality "1"^^xsd:nonNegativeInteger
    ] ;
    rdfs:subClassOf [ a owl:Restriction ;
        rdfs:comment "Een meetpunt kan verbonden zijn aan een enkele aangifte"@nl ;
        owl:onProperty :aangifte ;
        owl:someValuesFrom :Aangifte ;
        owl:minCardinality "0"^^xsd:nonNegativeInteger ;
        owl:maxCardinality "1"^^xsd:nonNegativeInteger
    ] ;
    rdfs:subClassOf [ a owl:Restriction ;
        rdfs:comment "Een meetpunt moet een enkele status hebben"@nl ;
        owl:onProperty adms:status ;
        owl:someValuesFrom adms:Status ;
        owl:minCardinality "1"^^xsd:nonNegativeInteger ;
        owl:maxCardinality "1"^^xsd:nonNegativeInteger
    ] ;
    rdfs:subClassOf [ a owl:Restriction ;
        rdfs:comment "Een meetpunt kan een revisie zijn van een andere systemen (optioneel)"@nl ;
        owl:onProperty prov:wasRevisionOf ;
        owl:someValuesFrom ssn:System ;
        owl:minCardinality "0"^^xsd:nonNegativeInteger ;
        owl:maxCardinality "1"^^xsd:nonNegativeInteger
    ] ;
    rdfs:subClassOf [ a owl:Restriction ;
        # *..* relation with ssn:deployedSystem
        owl:onProperty ssn:hasDeployment ;
        owl:someValuesFrom :Exploitatie ;
        owl:minCardinality "0"^^xsd:nonNegativeInteger
    ] ;
    rdfs:subClassOf [ a owl:Restriction ;
        # *..* relation with ssn:hasSubSystem
        owl:onProperty [ a owl:ObjectProperty ;
            owl:inverseOf ssn:hasSubSystem
        ] ;
        owl:someValuesFrom ssn:System ;
        owl:minCardinality "0"^^xsd:nonNegativeInteger
    ] ;
    rdfs:subClassOf [ a owl:Restriction ;
        rdfs:comment "Een meetpunt mag max 1 geometrie hebben"@nl ;
        owl:onProperty ogc:hasGeometry ;
        owl:minCardinality "0"^^xsd:nonNegativeInteger ;
        owl:maxCardinality "1"^^xsd:nonNegativeInteger
    ] ;
    rdfs:subClassOf [ a owl:Restriction ;
        rdfs:comment "Een meetpunt kan een typering hebben via dct:type"@nl ;
        owl:onProperty dct:type ;
        owl:minCardinality "0"^^xsd:nonNegativeInteger ;
        owl:maxCardinality "1"^^xsd:nonNegativeInteger
    ] ;
    rdfs:subClassOf [ a owl:Restriction ;
        rdfs:comment "Een meetpunt is verschillend van een emissiepunt (disjoint)"@nl ;
        owl:disjointWith :Emissiepunt
    ] ;
    rdfs:subClassOf [ a owl:Restriction ;
        rdfs:comment "Een meetpunt is verschillend van een onttrekkingspunt (disjoint)"@nl ;
        owl:disjointWith :Onttrekkingspunt
    ] ;
    rdfs:subClassOf [ a owl:Restriction ;
        # *..* relation with the inverse of ssn:hasSubSystem
        rdfs:comment "Een meetpunt kan meetinstrumenten hebben"@nl ;
        owl:onProperty ssn:hasSubSystem ;
        owl:someValuesFrom :MeetInstrument ;
        owl:minCardinality "0"^^xsd:nonNegativeInteger
    ] ;
    rdfs:subClassOf [ a owl:Restriction ;
        rdfs:comment "Een meetpunt kan meerdere eigenschappen hebben"@nl ;
        owl:onProperty ssn:hasProperty ;
        owl:someValuesFrom :SysteemEigenschap ;
        owl:minCardinality "0"^^xsd:nonNegativeInteger
    ] .

:MeetInstrument a owl:Class ;
    rdfs:label "Meetinstrument"@nl ;
    rdfs:comment "Een meetinstrument is een specifiek apparaat of systeem dat wordt gebruikt om metingen uit te voeren op meetpunten."@nl ;
    rdfs:subClassOf ssn:System, ogc:SpatialObject ;
    rdfs:subClassOf [ a owl:Restriction ;
        rdfs:comment "Een meetinstrument heeft externe identificaties (optioneel)"@nl ;
        owl:onProperty adms:identifier ;
        owl:someValuesFrom adms:Identifier ;
        owl:minCardinality "0"^^xsd:nonNegativeInteger
    ] ;
    rdfs:subClassOf [ a owl:Restriction ;
        rdfs:comment "Een meetinstrument moet een benaming hebben"@nl ;
        owl:onProperty rdfs:label ;
        owl:minCardinality "1"^^xsd:nonNegativeInteger
    ] ;
    rdfs:subClassOf [ a owl:Restriction ;
        rdfs:comment "Een meetinstrument moet een modificatie datum hebben"@nl ;
        owl:onProperty dct:modified ;
        owl:someValuesFrom xsd:dateTime ;
        owl:minCardinality "1"^^xsd:nonNegativeInteger ;
        owl:maxCardinality "1"^^xsd:nonNegativeInteger
    ] ;
    rdfs:subClassOf [ a owl:Restriction ;
        rdfs:comment "Een meetinstrument moet een creatie datum hebben"@nl ;
        owl:onProperty dct:created ;
        owl:someValuesFrom xsd:dateTime ;
        owl:minCardinality "1"^^xsd:nonNegativeInteger ;
        owl:maxCardinality "1"^^xsd:nonNegativeInteger
    ] ;
    rdfs:subClassOf [ a owl:Restriction ;
        rdfs:comment "Een meetinstrument moet een geldigheid start hebben"@nl ;
        owl:onProperty dct:issued ;
        owl:someValuesFrom xsd:date ;
        owl:minCardinality "1"^^xsd:nonNegativeInteger ;
        owl:maxCardinality "1"^^xsd:nonNegativeInteger
    ] ;
    rdfs:subClassOf [ a owl:Restriction ;
        rdfs:comment "Een meetinstrument kan een geldigheid einde hebben"@nl ;
        owl:onProperty dct:valid ;
        owl:someValuesFrom xsd:date ;
        owl:minCardinality "0"^^xsd:nonNegativeInteger ;
        owl:maxCardinality "1"^^xsd:nonNegativeInteger
    ] ;
    rdfs:subClassOf [ a owl:Restriction ;
        rdfs:comment "Een meetinstrument kan verbonden zijn aan een enkele aangifte"@nl ;
        owl:onProperty :aangifte ;
        owl:someValuesFrom :Aangifte ;
        owl:minCardinality "0"^^xsd:nonNegativeInteger ;
        owl:maxCardinality "1"^^xsd:nonNegativeInteger
    ] ;
    rdfs:subClassOf [ a owl:Restriction ;
        rdfs:comment "Een meetinstrument moet een enkele status hebben"@nl ;
        owl:onProperty adms:status ;
        owl:someValuesFrom adms:Status ;
        owl:minCardinality "1"^^xsd:nonNegativeInteger ;
        owl:maxCardinality "1"^^xsd:nonNegativeInteger
    ] ;
    rdfs:subClassOf [ a owl:Restriction ;
        rdfs:comment "Een meetinstrument kan een revisie zijn van een andere systemen (optioneel)"@nl ;
        owl:onProperty prov:wasRevisionOf ;
        owl:someValuesFrom ssn:System ;
        owl:minCardinality "0"^^xsd:nonNegativeInteger ;
        owl:maxCardinality "1"^^xsd:nonNegativeInteger
    ] ;
    rdfs:subClassOf [ a owl:Restriction ;
        # *..* relation with ssn:deployedSystem
        owl:onProperty ssn:hasDeployment ;
        owl:someValuesFrom :Exploitatie ;
        owl:minCardinality "0"^^xsd:nonNegativeInteger
    ] ;
    rdfs:subClassOf [ a owl:Restriction ;
        # *..* relation with ssn:hasSubSystem
        owl:onProperty [ a owl:ObjectProperty ;
            owl:inverseOf ssn:hasSubSystem
        ] ;
        owl:someValuesFrom ssn:System ;
        owl:minCardinality "0"^^xsd:nonNegativeInteger
    ] ;
    rdfs:subClassOf [ a owl:Restriction ;
        rdfs:comment "Een meetinstrument mag max 1 geometrie hebben"@nl ;
        owl:onProperty ogc:hasGeometry ;
        owl:minCardinality "0"^^xsd:nonNegativeInteger ;
        owl:maxCardinality "1"^^xsd:nonNegativeInteger
    ] ;
    rdfs:subClassOf [ a owl:Restriction ;
        rdfs:comment "Een meetinstrument kan een typering hebben via dct:type"@nl ;
        owl:onProperty dct:type ;
        owl:minCardinality "0"^^xsd:nonNegativeInteger ;
        owl:maxCardinality "1"^^xsd:nonNegativeInteger
    ] .

:Filter a owl:Class ;
    rdfs:label "Filter"@nl ;
    rdfs:comment "Een filter is een specifiek systeem dat wordt gebruikt om de kwaliteit van de uitstoot te verbeteren door het verwijderen of verminderen van schadelijke stoffen."@nl ;
    rdfs:subClassOf ssn:System, ogc:SpatialObject ;
    rdfs:subClassOf [ a owl:Restriction ;
        rdfs:comment "Een systeem heeft externe identificaties (optioneel)"@nl ;
        owl:onProperty adms:identifier ;
        owl:someValuesFrom adms:Identifier ;
        owl:minCardinality "0"^^xsd:nonNegativeInteger
    ] ;
    rdfs:subClassOf [ a owl:Restriction ;
        rdfs:comment "Een systeem moet een benaming hebben"@nl ;
        owl:onProperty rdfs:label ;
        owl:minCardinality "1"^^xsd:nonNegativeInteger
    ] ;
    rdfs:subClassOf [ a owl:Restriction ;
        rdfs:comment "Een systeem moet een modificatie datum hebben"@nl ;
        owl:onProperty dct:modified ;
        owl:someValuesFrom xsd:dateTime ;
        owl:minCardinality "1"^^xsd:nonNegativeInteger ;
        owl:maxCardinality "1"^^xsd:nonNegativeInteger
    ] ;
    rdfs:subClassOf [ a owl:Restriction ;
        rdfs:comment "Een systeem moet een creatie datum hebben"@nl ;
        owl:onProperty dct:created ;
        owl:someValuesFrom xsd:dateTime ;
        owl:minCardinality "1"^^xsd:nonNegativeInteger ;
        owl:maxCardinality "1"^^xsd:nonNegativeInteger
    ] ;
    rdfs:subClassOf [ a owl:Restriction ;
        rdfs:comment "Een systeem moet een geldigheid start hebben"@nl ;
        owl:onProperty dct:issued ;
        owl:someValuesFrom xsd:date ;
        owl:minCardinality "1"^^xsd:nonNegativeInteger ;
        owl:maxCardinality "1"^^xsd:nonNegativeInteger
    ] ;
    rdfs:subClassOf [ a owl:Restriction ;
        rdfs:comment "Een systeem kan een geldigheid einde hebben"@nl ;
        owl:onProperty dct:valid ;
        owl:someValuesFrom xsd:date ;
        owl:minCardinality "0"^^xsd:nonNegativeInteger ;
        owl:maxCardinality "1"^^xsd:nonNegativeInteger
    ] ;
    rdfs:subClassOf [ a owl:Restriction ;
        rdfs:comment "Een filter kan verbonden zijn aan een enkele aangifte"@nl ;
        owl:onProperty :aangifte ;
        owl:someValuesFrom :Aangifte ;
        owl:minCardinality "0"^^xsd:nonNegativeInteger ;
        owl:maxCardinality "1"^^xsd:nonNegativeInteger
    ] ;
    rdfs:subClassOf [ a owl:Restriction ;
        rdfs:comment "Een systeem moet een enkele status hebben"@nl ;
        owl:onProperty adms:status ;
        owl:someValuesFrom adms:Status ;
        owl:minCardinality "1"^^xsd:nonNegativeInteger ;
        owl:maxCardinality "1"^^xsd:nonNegativeInteger
    ] ;
    rdfs:subClassOf [ a owl:Restriction ;
        rdfs:comment "Een systeem kan een revisie zijn van een andere systemen (optioneel)"@nl ;
        owl:onProperty prov:wasRevisionOf ;
        owl:someValuesFrom ssn:System ;
        owl:minCardinality "0"^^xsd:nonNegativeInteger ;
        owl:maxCardinality "1"^^xsd:nonNegativeInteger
    ] ;
    rdfs:subClassOf [ a owl:Restriction ;
        # *..* relation with ssn:deployedSystem
        owl:onProperty ssn:hasDeployment ;
        owl:someValuesFrom :Exploitatie ;
        owl:minCardinality "0"^^xsd:nonNegativeInteger
    ] ;
    rdfs:subClassOf [ a owl:Restriction ;
        # *..* relation with ssn:hasSubSystem
        owl:onProperty [ a owl:ObjectProperty ;
            owl:inverseOf ssn:hasSubSystem
        ] ;
        owl:someValuesFrom ssn:System ;
        owl:minCardinality "0"^^xsd:nonNegativeInteger
    ] ;
    rdfs:subClassOf [ a owl:Restriction ;
        rdfs:comment "Een systeem mag max 1 geometrie hebben"@nl ;
        owl:onProperty ogc:hasGeometry ;
        owl:minCardinality "0"^^xsd:nonNegativeInteger ;
        owl:maxCardinality "1"^^xsd:nonNegativeInteger
    ] ;
    rdfs:subClassOf [ a owl:Restriction ;
        rdfs:comment "Een systeem kan een typering hebben via dct:type"@nl ;
        owl:onProperty dct:type ;
        owl:minCardinality "0"^^xsd:nonNegativeInteger ;
        owl:maxCardinality "1"^^xsd:nonNegativeInteger
    ] .

# Proces Procedures
:TransportProcedure a owl:Class, skos:Concept ;
    rdfs:label "Transport Procedure"@nl ;
    rdfs:comment "Een transport procedure is een specifieke procedure die betrekking heeft op het transport van stoffen binnen of buiten een proces."@nl ;
    rdfs:subClassOf sosa:Procedure .
:VerwerkingProcedure a owl:Class, skos:Concept ;
    rdfs:label "Verwerkings Procedure"@nl ;
    rdfs:comment "Een verwerkings procedure is een specifieke procedure die betrekking heeft op de verwerking van stoffen binnen een proces."@nl ;
    rdfs:subClassOf sosa:Procedure .
:OnttrekkingProcedure a owl:Class, skos:Concept ;
    rdfs:label "Onttrekking Procedure"@nl ;
    rdfs:comment "Een onttrekking procedure is een specifieke procedure die betrekking heeft op het transport van grondstoffen binnen een proces."@nl ;
    rdfs:subClassOf :TransportProcedure .
:EmissieProcedure a owl:Class, skos:Concept ;
    rdfs:label "Emissie Procedure"@nl ;
    rdfs:comment "Een emissie procedure is een specifieke procedure die betrekking heeft op het uitstoten of lozen van stoffen aan emissiepunten."@nl ;
    rdfs:subClassOf :TransportProcedure .
:MeetProcedure a owl:Class, skos:Concept ;
    rdfs:label "Meetprocedure"@nl ;
    rdfs:comment "Een meetprocedure is een specifieke procedure die wordt gebruikt om metingen uit te voeren op meetpunten."@nl ;
    rdfs:subClassOf sosa:Procedure .

# Observatie
:Observatie a owl:Class ;
    rdfs:label "Observatie"@nl ;
    rdfs:comment "Een observatie is een waarneming of meting die is uitgevoerd op een meetpunt."@nl ;
    rdfs:subClassOf sosa:Observation ;
    hydra:search [ a hydra:IriTemplate ;
        hydra:template "https://data.riepr.omgeving.vlaanderen.be/id/observatie/{uuid}"^^hydra:Rfc6570Template ;
        hydra:mapping [ hydra:variable "uuid" ; hydra:property :localId ; hydra:required true ]
    ] ;
    rdfs:subClassOf [ a owl:Restriction ;
        rdfs:comment "Een observatie moet gekoppeld zijn aan exact één meetpunt"@nl ;
        owl:onProperty sosa:hasFeatureOfInterest ;
        owl:someValuesFrom :Meetpunt ;
        owl:minCardinality "1"^^xsd:nonNegativeInteger ;
        owl:maxCardinality "1"^^xsd:nonNegativeInteger
    ] ;
    rdfs:subClassOf [ a owl:Restriction ;
        rdfs:comment "Een observatie moet een resultaat hebben."@nl ;
        owl:onProperty sosa:hasResult ;
        owl:someValuesFrom sosa:Result ;
        owl:minCardinality "0"^^xsd:nonNegativeInteger ;
        owl:maxCardinality "1"^^xsd:nonNegativeInteger
    ] .

:Onttrekking a owl:Class ;
    rdfs:label "Onttrekking"@nl ;
    rdfs:comment "Een onttrekking is een specifiek resultaat dat betrekking heeft op het winnen of bemonsteren van grondstoffen aan onttrekkingspunten over of op een bepaalde periode of momentopname."@nl ;
    rdfs:subClassOf sosa:Result, prov:Entity ;
    owl:equivalentClass [ a owl:Restriction ;
        rdfs:comment "Een onttrekking moet gelinked zijn aan een proces variabele die binnen een proces wordt gebruikt (als uitvoer) dat geimplementeerd wordt door een onttrekkingspunt"@nl ;
        owl:onProperty pplan:correspondsToVariable ;
        owl:someValuesFrom [ a owl:Restriction ;
            owl:onProperty pplan:isOutputVarOf ;
            owl:someValuesFrom [ a owl:Restriction ;
                owl:onProperty ssn:implementedBy ;
                owl:someValuesFrom :Onttrekkingspunt
            ]
        ]
    ] ;
    rdfs:subClassOf [ a owl:Restriction ;
        # *..* relation with sosa:isResultOf
        owl:onProperty sosa:isResultOf ;
        owl:someValuesFrom sosa:Observation ;
        owl:minCardinality "0"^^xsd:nonNegativeInteger
    ] .

:Emissie a owl:Class ;
    rdfs:label "Emissie"@nl ;
    rdfs:comment "Een emissie is een specifiek resultaat dat betrekking heeft op het uitstoten of lozen van stoffen aan emissiepunten over of op een bepaalde periode of momentopname."@nl ;
    rdfs:subClassOf sosa:Result, prov:Entity ;
    owl:equivalentClass [ a owl:Restriction ;
        rdfs:comment "Een emissie moet gelinked zijn aan een proces variabele die binnen een proces wordt gebruikt (als uitvoer) dat geimplementeerd wordt door een emissiepunt"@nl ;
        owl:onProperty pplan:correspondsToVariable ;
        owl:someValuesFrom [ a owl:Restriction ;
            owl:onProperty pplan:isOutputVarOf ;
            owl:someValuesFrom [ a owl:Restriction ;
                owl:onProperty ssn:implementedBy ;
                owl:someValuesFrom :Emissiepunt
            ]
        ]
    ] ;
    rdfs:subClassOf [ a owl:Restriction ;
        # *..* relation with sosa:hasResult
        owl:onProperty sosa:isResultOf ;
        owl:someValuesFrom sosa:Observation ;
        owl:minCardinality "0"^^xsd:nonNegativeInteger
    ] .

:Productievolume a owl:Class ;
    rdfs:label "Productievolume"@nl ;
    rdfs:comment "Een productie volume is een specifiek resultaat dat betrekking heeft op de hoeveelheid geproduceerde goederen of diensten binnen een proces over of op een bepaalde periode."@nl ;
    rdfs:subClassOf sosa:Result, prov:Entity ;
    owl:equivalentClass [ a owl:Restriction ;
        rdfs:comment "Een productie volume moet gelinked zijn aan een proces variabele die binnen een proces wordt gebruikt (als uitvoer) dat geimplementeerd wordt door een exploitatie"@nl ;
        owl:onProperty pplan:correspondsToVariable ;
        owl:someValuesFrom [ a owl:Restriction ;
            owl:onProperty pplan:isOutputVarOf ;
            owl:someValuesFrom [ a owl:Restriction ;
                owl:onProperty ssn:implementedBy ;
                owl:someValuesFrom :Exploitatie
            ]
        ]
    ] ;
    rdfs:subClassOf [ a owl:Restriction ;
        # *..* relation with sosa:isResultOf
        owl:onProperty sosa:isResultOf ;
        owl:someValuesFrom sosa:Observation ;
        owl:minCardinality "0"^^xsd:nonNegativeInteger
    ] .

:Rubriek a owl:Class ;
    rdfs:label "Rubriek"@nl ;
    rdfs:comment "Een rubriek is een specifieke classificatie die wordt gebruikt om activiteiten te categoriseren volgens de regelgeving."@nl ;
    rdfs:subClassOf skos:Concept ;
    rdfs:subClassOf [ a owl:Restriction ;
        rdfs:comment "Een rubriek moet een code hebben"@nl ;
        owl:onProperty skos:notation ;
        owl:minCardinality "1"^^xsd:nonNegativeInteger ;
        owl:maxCardinality "1"^^xsd:nonNegativeInteger
    ] ;
    rdfs:subClassOf [ a owl:Restriction ;
        rdfs:comment "Een rubriek kan een beschrijving hebben"@nl ;
        owl:onProperty skos:definition ;
        owl:minCardinality "0"^^xsd:nonNegativeInteger ;
        owl:maxCardinality "1"^^xsd:nonNegativeInteger
    ] ;
    rdfs:subClassOf [ a owl:Restriction ;
        rdfs:comment "Een rubriek kan een typering hebben via dct:type"@nl ;
        owl:onProperty dct:type ;
        owl:minCardinality "1"^^xsd:nonNegativeInteger ;
        owl:maxCardinality "1"^^xsd:nonNegativeInteger
    ] .

:Transactie a owl:Class ;
    rdfs:label "Transactie"@nl ;
    rdfs:comment "Een transactie is een proces van indienen, verwerken en goedkeuren van documenten door de rapporteringsplichtige."@nl ;
    rdfs:subClassOf prov:Activity ;
    rdfs:subClassOf [ a owl:Restriction ;
        rdfs:comment "Een transactie genereert een of meerdere aangiften"@nl ;
        owl:onProperty dossier:genereert ;
        owl:someValuesFrom :Aangifte ;
        owl:minCardinality "1"^^xsd:nonNegativeInteger ;
    ] ;
    rdfs:subClassOf [ a owl:Restriction ;
        rdfs:comment "Een transactie heeft een start datum waarop de transactie is gestart"@nl ;
        owl:onProperty prov:startedAtTime ;
        owl:someValuesFrom xsd:dateTime ;
        owl:minCardinality "1"^^xsd:nonNegativeInteger ;
        owl:maxCardinality "1"^^xsd:nonNegativeInteger
    ] ;
    rdfs:subClassOf [ a owl:Restriction ;
        rdfs:comment "Een transactie heeft een eind datum waarop de transactie is beëindigd"@nl ;
        owl:onProperty prov:endedAtTime ;
        owl:someValuesFrom xsd:dateTime ;
        owl:minCardinality "0"^^xsd:nonNegativeInteger ;
        owl:maxCardinality "1"^^xsd:nonNegativeInteger
    ] ;
    rdfs:subClassOf [ a owl:Restriction ;
        rdfs:comment "Een transactie heeft een verantwoordelijke agent"@nl ;
        owl:onProperty prov:wasAssociatedWith ;
        owl:someValuesFrom prov:Agent ;
        owl:minCardinality "1"^^xsd:nonNegativeInteger ;
        owl:maxCardinality "1"^^xsd:nonNegativeInteger
    ] .

:Aangifte a owl:Class ;
    rdfs:label "Aangifte"@nl ;
    rdfs:comment "Een aangifte is een document dat wordt ingediend bij de overheid."@nl ;
    hydra:search [ a hydra:IriTemplate ;
        hydra:template "https://data.riepr.omgeving.vlaanderen.be/id/aangifte/{vlaanderenId}"^^hydra:Rfc6570Template ;
        hydra:mapping [ hydra:variable "vlaanderenId" ; hydra:property :vlaanderenId ; hydra:required true ]
    ] ;
    rdfs:subClassOf dossier:Stuk ;
    rdfs:subClassOf [ a owl:Restriction ;
        rdfs:comment "Een aangifte heeft optioneel een auteur (die verschillend kan zijn dan de indiener)."@nl ;
        owl:onProperty prov:wasAssociatedWith ;
        owl:minCardinality "0"^^xsd:nonNegativeInteger ;
        owl:maxCardinality "1"^^xsd:nonNegativeInteger
    ] ;
    rdfs:subClassOf [ a owl:Restriction ;
        rdfs:comment "Een aangifte heeft betrekking tot meerdere observaties."@nl ;
        owl:onProperty dct:subject ;
        owl:someValuesFrom :Observatie
    ] ;
    rdfs:subClassOf [ a owl:Restriction ;
        rdfs:comment "Een aangifte heeft betrekking tot een enkele exploitatie."@nl ;
        owl:onProperty dct:subject ;
        owl:onClass :Exploitatie ;
        owl:qualifiedCardinality "1"^^xsd:nonNegativeInteger
    ] ;
    rdfs:subClassOf [ a owl:Restriction ;
        rdfs:comment "Een aangifte heeft een datum van indiening."@nl ;
        owl:onProperty dct:created ;
        owl:someValuesFrom xsd:date ;
        owl:minCardinality "1"^^xsd:nonNegativeInteger ;
        owl:maxCardinality "1"^^xsd:nonNegativeInteger
    ] ;
    rdfs:subClassOf [ a owl:Restriction ;
        rdfs:comment "Een aangifte kan deel zijn van een andere aangifte."@nl ;
        owl:onProperty dct:isPartOf ;
        owl:someValuesFrom :Aangifte ;
        owl:minCardinality "0"^^xsd:nonNegativeInteger ;
        owl:maxCardinality "1"^^xsd:nonNegativeInteger
    ] ;
    rdfs:subClassOf [ a owl:Restriction ;
        rdfs:comment "Een aangifte heeft een informatie classificatie."@nl ;
        owl:onProperty dossier:informatieclassificatie ;
        owl:minCardinality "0"^^xsd:nonNegativeInteger ;
        owl:maxCardinality "1"^^xsd:nonNegativeInteger
    ] .

# --------------------------------------- #
# Object Properties
# --------------------------------------- #
# Object properties worden vermeden waar mogelijk
# Business benamingen worden in concepten vastgelegd

:rubriek a owl:ObjectProperty ;
    rdfs:label "Rubriek"@nl ;
    rdfs:comment "De rubriek die van toepassing is op een proces of installatie."@nl ;
    rdfs:domain :Proces ;
    rdfs:range :Rubriek .

:parameter a owl:ObjectProperty ;
    rdfs:label "Parameter"@nl ;
    rdfs:comment "De parameter die wordt gebruikt bij een eigenschap of meting."@nl ;
    rdfs:domain :SysteemEigenschap ;
    rdfs:range pplan:Variable .

:aangifte a owl:ObjectProperty ;
    rdfs:label "Aangifte"@nl ;
    rdfs:comment "De aangifte die gerelateerd is aan een exploitatie of observatie."@nl ;
    rdfs:range :Aangifte .

# --------------------------------------- #
# Data Properties
# --------------------------------------- #

:localId a owl:DatatypeProperty ;
    rdfs:label "Local Identifier"@en ;
    rdfs:comment "Een local identifier is een unieke identificatie binnen de context van RIE-IEPR."@en ;
    rdfs:range xsd:string .

:vlaanderenId a owl:DatatypeProperty ;
    rdfs:label "Vlaanderen Identifier"@nl ;
    rdfs:comment "Een unieke identificatie binnen de context van Vlaanderen, gebruikt voor het identificeren van entiteiten zoals aangiften."@nl ;
    rdfs:range xsd:string .

# --------------------------------------- #
# Individuals
# --------------------------------------- #
# Status concepten voor adms:status
:in_gebruik a adms:Status, skos:Concept ;
    rdfs:label "In gebruik"@nl ;
    rdfs:comment "De status 'In gebruik' geeft aan dat een entiteit momenteel in gebruik is."@nl ;
    skos:prefLabel "In gebruik"@nl ;
    rdfs:equivalentClass <http://purl.org/adms/status/Completed> .
:tijdelijk_uit_dienst a adms:Status, skos:Concept ;
    rdfs:label "Tijdelijk uit dienst"@nl ;
    rdfs:comment "De status 'Tijdelijk uit dienst' geeft aan dat een entiteit momenteel niet in gebruik is."@nl ;
    skos:prefLabel "Tijdelijk uit dienst"@nl ;
    rdfs:equivalentClass <http://purl.org/adms/status/Deprecated> .
:definitief_uit_dienst a adms:Status, skos:Concept ;
    rdfs:label "Definitief uit dienst"@nl ;
    rdfs:comment "De status 'Definitief uit dienst' geeft aan dat een entiteit permanent buiten gebruik is gesteld."@nl ;
    skos:prefLabel "Definitief uit dienst"@nl ;
    rdfs:equivalentClass <http://purl.org/adms/status/Withdrawn> .
:ontmanteld a adms:Status, skos:Concept ;
    rdfs:label "Ontmanteld"@nl ;
    rdfs:comment "De status 'Ontmanteld' geeft aan dat een entiteit is afgebroken of verwijderd."@nl ;
    skos:prefLabel "Ontmanteld"@nl ;
    rdfs:equivalentClass <http://purl.org/adms/status/Withdrawn> .
:voorgesteld a adms:Status, skos:Concept ;
    rdfs:label "Voorgesteld"@nl ;
    rdfs:comment "De voorgestelde status geeft aan dat een entiteit is voorgesteld door de overheid maar nog niet bevestigd is."@nl ;
    skos:prefLabel "Voorgesteld"@nl ;
    rdfs:equivalentClass <http://purl.org/adms/status/UnderDevelopment> .

# --------------------------------------- #
# Axioms
# --------------------------------------- #
[ a owl:Class ;
    rdfs:comment "Een proces met een emissieprocedure moet stoffen uitstoten of lozen aan een emissiepunt"@nl ;
    owl:intersectionOf ( :Proces [ a owl:Restriction ;
        owl:someValuesFrom :EmissieProcedure
    ] )
] rdfs:subClassOf [ a owl:Restriction ;
    owl:onProperty ssn:implementedBy ;
    owl:someValuesFrom :Emissiepunt
] .

[ a owl:Class ;
    rdfs:comment "Een proces met een onttrekkingprocedure moet stoffen onttrekken aan een bron"@nl ;
    owl:intersectionOf ( :Proces [ a owl:Restriction ;
        owl:someValuesFrom :OnttrekkingProcedure
    ] )
] rdfs:subClassOf [ a owl:Restriction ;
    owl:onProperty ssn:implementedBy ;
    owl:someValuesFrom :Onttrekkingspunt
] .

[ a owl:Class ;
    rdfs:comment "Een proces met een VerwerkingProcedure moet stoffen verwerken binnen een installatie"@nl ;
    owl:intersectionOf ( :Proces [ a owl:Restriction ;
        owl:someValuesFrom :VerwerkingProcedure
    ] )
] rdfs:subClassOf [ a owl:Restriction ;
    owl:onProperty ssn:implementedBy ;
    owl:someValuesFrom :Installatie
] .

[ a owl:Class ;
    rdfs:comment "Een proces met een meetprocedure moet metingen uitvoeren op een meetpunt"@nl ;
    owl:intersectionOf ( :Proces [ a owl:Restriction ;
        owl:someValuesFrom :MeetProcedure
    ] )
] rdfs:subClassOf [ a owl:Restriction ;
    owl:onProperty ssn:implementedBy ;
    owl:someValuesFrom :Meetpunt
] .

# p-plan does not have an inverse indication for pplan:hasOutputVar
# It does have an inverse for hasInputVar
pplan:isOutputVarOf owl:inverseOf pplan:hasOutputVar .
