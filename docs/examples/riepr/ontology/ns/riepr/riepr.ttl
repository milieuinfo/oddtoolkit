        owl:someValuesFrom xsd:date ;
        owl:minCardinality "0"^^xsd:nonNegativeInteger ;
        owl:maxCardinality "1"^^xsd:nonNegativeInteger
    ] ;
    rdfs:subClassOf [ a owl:Restriction ;
        rdfs:comment "Een filter kan verbonden zijn aan een enkele aangifte"@nl ;
        owl:onProperty :aangifte ;
        owl:someValuesFrom :Aangifte ;
        owl:minCardinality "0"^^xsd:nonNegativeInteger ;
        owl:maxCardinality "1"^^xsd:nonNegativeInteger
    ] ;
    rdfs:subClassOf [ a owl:Restriction ;
        rdfs:comment "Een systeem moet een enkele status hebben"@nl ;
        owl:onProperty adms:status ;
        owl:someValuesFrom adms:Status ;
        owl:minCardinality "1"^^xsd:nonNegativeInteger ;
        owl:maxCardinality "1"^^xsd:nonNegativeInteger
    ] ;
    rdfs:subClassOf [ a owl:Restriction ;
        rdfs:comment "Een systeem kan een revisie zijn van een andere systemen (optioneel)"@nl ;
        owl:onProperty prov:wasRevisionOf ;
        owl:someValuesFrom ssn:System ;
        owl:minCardinality "0"^^xsd:nonNegativeInteger ;
        owl:maxCardinality "1"^^xsd:nonNegativeInteger
    ] ;
    rdfs:subClassOf [ a owl:Restriction ;
        # *..* relation with ssn:deployedSystem
        owl:onProperty ssn:hasDeployment ;
        owl:someValuesFrom :Exploitatie ;
        owl:minCardinality "0"^^xsd:nonNegativeInteger
    ] ;
    rdfs:subClassOf [ a owl:Restriction ;
        # *..* relation with ssn:hasSubSystem
        owl:onProperty [ a owl:ObjectProperty ;
            owl:inverseOf ssn:hasSubSystem
        ] ;
        owl:someValuesFrom ssn:System ;
        owl:minCardinality "0"^^xsd:nonNegativeInteger
    ] ;
    rdfs:subClassOf [ a owl:Restriction ;
        rdfs:comment "Een systeem mag max 1 geometrie hebben"@nl ;
        owl:onProperty ogc:hasGeometry ;
        owl:minCardinality "0"^^xsd:nonNegativeInteger ;
        owl:maxCardinality "1"^^xsd:nonNegativeInteger
    ] ;
    rdfs:subClassOf [ a owl:Restriction ;
        rdfs:comment "Een filter kan een typering hebben via dct:type"@nl ;
        # Codelijst: https://github.com/milieuinfo/codelijst-rie-iepr/blob/main/src/source/filter_type.csv
        owl:onProperty dct:type ;
        owl:minCardinality "0"^^xsd:nonNegativeInteger ;
        owl:maxCardinality "1"^^xsd:nonNegativeInteger
    ] ;
    hydra:search [ a hydra:IriTemplate ;
        hydra:template "https://data.mjv.omgeving.vlaanderen.be/id/filter/{uuid}/{issued}/{created}"^^hydra:Rfc6570Template ;
        hydra:mapping [ hydra:variable "uuid" ; hydra:property :localId ; hydra:required true ] ,
                      [ hydra:variable "issued" ; hydra:property dct:issued ; hydra:required true ] ,
                      [ hydra:variable "created" ; hydra:property dct:created ; hydra:required true ]
    ] .

:Rubriek a owl:Class ;
    rdfs:label "Rubriek"@nl ;
    rdfs:comment "Een rubriek is een specifieke classificatie die wordt gebruikt om activiteiten te categoriseren volgens de regelgeving."@nl ;
    rdfs:subClassOf skos:Concept ;
    hydra:search [ a hydra:IriTemplate ;
        hydra:template "https://data.mjv.omgeving.vlaanderen.be/id/rubriek/{uuid}"^^hydra:Rfc6570Template ;
        hydra:mapping [ hydra:variable "uuid" ; hydra:property :localId ; hydra:required true ]
    ] ;
    rdfs:subClassOf [ a owl:Restriction ;
        rdfs:comment "Een rubriek moet een code hebben"@nl ;
        owl:onProperty skos:notation ;
        owl:minCardinality "1"^^xsd:nonNegativeInteger ;
        owl:maxCardinality "1"^^xsd:nonNegativeInteger
    ] ;
    rdfs:subClassOf [ a owl:Restriction ;
        rdfs:comment "Een rubriek kan een beschrijving hebben"@nl ;
        owl:onProperty skos:definition ;
        owl:minCardinality "0"^^xsd:nonNegativeInteger ;
        owl:maxCardinality "1"^^xsd:nonNegativeInteger
    ] ;
    rdfs:subClassOf [ a owl:Restriction ;
        rdfs:comment "Een rubriek kan een typering hebben via dct:type"@nl ;
        # Codelijst: https://github.com/milieuinfo/codelijst-rie-iepr/blob/main/src/source/rubriek_type.csv
        owl:onProperty dct:type ;
        owl:minCardinality "1"^^xsd:nonNegativeInteger ;
        owl:maxCardinality "1"^^xsd:nonNegativeInteger
    ] ;
    rdfs:subClassOf [ a owl:Restriction ;
        rdfs:comment "Een rubriek kan een primaire bron hebben (VITO, ...)"@nl ;
        owl:onProperty prov:hadPrimarySource ;
        owl:minCardinality "0"^^xsd:nonNegativeInteger ;
        owl:maxCardinality "1"^^xsd:nonNegativeInteger
    ] .

## Feature of interests
:Uitwisseling a owl:Class ;
    rdfs:label "Uitwisseling"@nl ;
    rdfs:comment "Een uitwisseling is een specifiek uitwisselingsgebeurtenis dat betrekking heeft op het overdragen of ontvangen van stoffen aan uitwisselpunt(en) over of op een bepaalde periode of momentopname."@nl ;
    rdfs:subClassOf prov:Entity, sosa:FeatureOfInterest ;
    hydra:search [ a hydra:IriTemplate ;
        hydra:template "https://data.mjv.omgeving.vlaanderen.be/id/uitwisseling/{uuid}"^^hydra:Rfc6570Template ;
        hydra:mapping [ hydra:variable "uuid" ; hydra:property :localId ; hydra:required true ]
    ] ;
    rdfs:subClassOf [ a owl:Restriction ;
        rdfs:comment "Een uitwisseling moet gekoppeld zijn aan een proces"@nl ;
        owl:onProperty sosa:hasFeatureOfInterest ;
        owl:someValuesFrom :Proces ;
        owl:minCardinality "1"^^xsd:nonNegativeInteger
    ] ;
    rdfs:subClassOf [ a owl:Restriction ;
        # *..* relation with sosa:isFeatureOfInterestOf
        owl:onProperty sosa:isFeatureOfInterestOf ;
        owl:someValuesFrom sosa:Observation ;
        owl:minCardinality "0"^^xsd:nonNegativeInteger
    ] .

:Onttrekking a owl:Class ;
    rdfs:label "Onttrekking"@nl ;
    rdfs:comment "Een onttrekking is een specifiek onttrekkingsevent dat betrekking heeft op het winnen of bemonsteren van grondstoffen aan onttrekkingspunten over of op een bepaalde periode of momentopname."@nl ;
    rdfs:subClassOf prov:Entity, sosa:FeatureOfInterest ;
    hydra:search [ a hydra:IriTemplate ;
        hydra:template "https://data.mjv.omgeving.vlaanderen.be/id/onttrekking/{uuid}"^^hydra:Rfc6570Template ;
        hydra:mapping [ hydra:variable "uuid" ; hydra:property :localId ; hydra:required true ]
    ] ;
    rdfs:subClassOf [ a owl:Restriction ;
        rdfs:comment "Een uitwisseling moet gekoppeld zijn aan een proces"@nl ;
        owl:onProperty sosa:hasFeatureOfInterest ;
        owl:someValuesFrom :Proces ;
        owl:minCardinality "1"^^xsd:nonNegativeInteger
    ] ;
    rdfs:subClassOf [ a owl:Restriction ;
        # *..* relation with sosa:isFeatureOfInterestOf
        owl:onProperty sosa:isFeatureOfInterestOf ;
        owl:someValuesFrom sosa:Observation ;
        owl:minCardinality "0"^^xsd:nonNegativeInteger
    ] .

:Emissie a owl:Class ;
    rdfs:label "Emissie"@nl ;
    rdfs:comment "Een emissie is een specifiek emissieevent dat betrekking heeft op het uitstoten of lozen van stoffen aan emissiepunten over of op een bepaalde periode of momentopname."@nl ;
    rdfs:subClassOf prov:Entity, sosa:FeatureOfInterest ;
    hydra:search [ a hydra:IriTemplate ;
        hydra:template "https://data.mjv.omgeving.vlaanderen.be/id/emissie/{uuid}"^^hydra:Rfc6570Template ;
        hydra:mapping [ hydra:variable "uuid" ; hydra:property :localId ; hydra:required true ]
    ] ;
    rdfs:subClassOf [ a owl:Restriction ;
        rdfs:comment "Een uitwisseling moet gekoppeld zijn aan een proces"@nl ;
        owl:onProperty sosa:hasFeatureOfInterest ;
        owl:someValuesFrom :Proces ;
        owl:minCardinality "1"^^xsd:nonNegativeInteger
    ] ;
    rdfs:subClassOf [ a owl:Restriction ;
        # *..* relation with sosa:isFeatureOfInterestOf
        owl:onProperty sosa:isFeatureOfInterestOf ;
        owl:someValuesFrom sosa:Observation ;
        owl:minCardinality "0"^^xsd:nonNegativeInteger
    ] .

## Observaties
:Observatie a owl:Class ;
    rdfs:label "Observatie"@nl ;
    rdfs:comment "Een observatie is een waarneming of meting uitgevoerd op een emissie via een meetinstrument."@nl ;
    rdfs:subClassOf sosa:Observation ;
    hydra:search [ a hydra:IriTemplate ;
        hydra:template "https://data.mjv.omgeving.vlaanderen.be/id/observatie/{uuid}"^^hydra:Rfc6570Template ;
        hydra:mapping [ hydra:variable "uuid" ; hydra:property :localId ; hydra:required true ]
    ] ;
    rdfs:subClassOf [ a owl:Restriction ;
        rdfs:comment "Een observatie is optioneel gekoppeld aan een aangifte tenzij het in concept staat."@nl ;
        owl:onProperty :aangifte ;
        owl:someValuesFrom :Aangifte ;
        owl:minCardinality "0"^^xsd:nonNegativeInteger ;
        owl:maxCardinality "1"^^xsd:nonNegativeInteger
    ] ;
    rdfs:subClassOf [ a owl:Restriction ;
        rdfs:comment "Een observatie is gekoppeld aan een Emissie, Onttrekking of Uitwisseling"@nl ;
        owl:onProperty sosa:hasFeatureOfInterest ;
        owl:someValuesFrom :Gebeurtenis ;
        owl:minCardinality "1"^^xsd:nonNegativeInteger ;
        owl:maxCardinality "1"^^xsd:nonNegativeInteger
    ] ;
    rdfs:subClassOf [ a owl:Restriction ;
        rdfs:comment "Een observatie kan gedaan zijn door een meetinstrument"@nl ;
        owl:onProperty sosa:madeBySensor ;
        owl:someValuesFrom :Meetinstrument ;
        owl:minCardinality "0"^^xsd:nonNegativeInteger ;
        owl:maxCardinality "1"^^xsd:nonNegativeInteger
    ] ;
    rdfs:subClassOf [ a owl:Restriction ;
        rdfs:comment "Een observatie heeft één resultaat."@nl ;
        owl:onProperty sosa:hasResult ;
        owl:someValuesFrom :Resultaat ;
        owl:minCardinality "1"^^xsd:nonNegativeInteger ;
        owl:maxCardinality "1"^^xsd:nonNegativeInteger
    ] ;
    rdfs:subClassOf [ a owl:Restriction ;
        rdfs:comment "Een observatie kan een resultaat tijdstip hebben"@nl ;
        owl:onProperty sosa:resultTime ;
        owl:someValuesFrom xsd:dateTime ;
        owl:minCardinality "0"^^xsd:nonNegativeInteger ;
        owl:maxCardinality "1"^^xsd:nonNegativeInteger
    ] ;
    rdfs:subClassOf [ a owl:Restriction ;
        rdfs:comment "Een observatie kan een verschijnsel tijdsinterval hebben"@nl ;
        owl:onProperty sosa:phenomenonTime ;
        owl:minCardinality "0"^^xsd:nonNegativeInteger ;
        owl:maxCardinality "1"^^xsd:nonNegativeInteger
    ] ;
    rdfs:subClassOf [ a owl:Restriction ;
        rdfs:comment "Een observatie kan een geobserveerde eigenschap hebben"@nl ;
        owl:onProperty sosa:observedProperty ;
        owl:minCardinality "0"^^xsd:nonNegativeInteger ;
        owl:maxCardinality "1"^^xsd:nonNegativeInteger
    ] ;
    rdfs:subClassOf [ a owl:Restriction ;
        rdfs:comment "Een observatie kan een gebruikte bepalingsmethode hebben"@nl ;
        owl:onProperty sosa:usedProcedure ;
        # Codelijst: operationeel_bepalingsmethode
        owl:minCardinality "0"^^xsd:nonNegativeInteger ;
        owl:maxCardinality "1"^^xsd:nonNegativeInteger
    ] .

:Resultaat a owl:Class ;
    rdfs:label "Resultaat"@nl ;
    rdfs:comment "Een resultaat is de waarde van een observatie."@nl ;
    rdfs:subClassOf sosa:Result, prov:Entity ;
    hydra:search [ a hydra:IriTemplate ;
        hydra:template "https://data.mjv.omgeving.vlaanderen.be/id/resultaat/{uuid}"^^hydra:Rfc6570Template ;
        hydra:mapping [ hydra:variable "uuid" ; hydra:property :localId ; hydra:required true ]
    ] ;
    rdfs:subClassOf [ a owl:Restriction ;
        rdfs:comment "Een resultaat kan een numerieke waarde hebben"@nl ;
        owl:onProperty qudt:numericValue ;
        owl:someValuesFrom xsd:decimal ;
        owl:minCardinality "0"^^xsd:nonNegativeInteger ;
        owl:maxCardinality "1"^^xsd:nonNegativeInteger
    ] ;
    rdfs:subClassOf [ a owl:Restriction ;
        rdfs:comment "Een resultaat kan een eenheid hebben"@nl ;
        owl:onProperty qudt:unit ;
        owl:minCardinality "0"^^xsd:nonNegativeInteger ;
        owl:maxCardinality "1"^^xsd:nonNegativeInteger
    ] ;
    rdfs:subClassOf [ a owl:Restriction ;
        rdfs:comment "Een resultaat kan een tekstuele waarde hebben"@nl ;
        owl:onProperty rdfs:comment ;
        owl:someValuesFrom xsd:string ;
        owl:minCardinality "0"^^xsd:nonNegativeInteger ;
        owl:maxCardinality "1"^^xsd:nonNegativeInteger
    ] .

## Aangiftes
:Aangiftebundel a owl:Class ;
    rdfs:label "Aangiftebundel"@nl ;
    rdfs:comment "Een aangiftebundel is een verzameling van aangiften die samen worden ingediend bij de overheid door een enkele exploitant."@nl ;
    rdfs:subClassOf dossier:Stuk ;
    hydra:search [ a hydra:IriTemplate ;
        hydra:template "https://data.mjv.omgeving.vlaanderen.be/id/aangifte/{vlaanderenId}"^^hydra:Rfc6570Template ;
        hydra:mapping [ hydra:variable "vlaanderenId" ; hydra:property :vlaanderenId ; hydra:required true ]
    ] ;
    rdfs:subClassOf [ a owl:Restriction ;
        rdfs:comment "Een aangifte bundel heeft een typering."@nl ;
        # Codelijst: https://github.com/milieuinfo/codelijst-rie-iepr/blob/main/src/source/aangifte_type.csv
        owl:onProperty dct:type ; # e.g. https://data.omgeving.vlaanderen.be/id/concept/riepr/aangifte-type/structuur
        owl:minCardinality "1"^^xsd:nonNegativeInteger ;
        owl:maxCardinality "1"^^xsd:nonNegativeInteger
    ] ;
    rdfs:subClassOf [ a owl:Restriction ;
        rdfs:comment "Een aangiftebundel is gelinkt aan de exploitant"@nl ;
        owl:onProperty dct:creator ;
        owl:someValuesFrom :Exploitant ;
        owl:minCardinality "1"^^xsd:nonNegativeInteger ;
        owl:maxCardinality "1"^^xsd:nonNegativeInteger
    ] ;
    rdfs:subClassOf [ a owl:Restriction ;
        rdfs:comment "Een aangifte bundel heeft een datum van indiening."@nl ;
        owl:onProperty dct:created ;
        owl:someValuesFrom xsd:date ;
        owl:minCardinality "1"^^xsd:nonNegativeInteger ;
        owl:maxCardinality "1"^^xsd:nonNegativeInteger
    ] ;
    rdfs:subClassOf [ a owl:Restriction ;
        rdfs:comment "Een aangifte kan een datum van goedkeuring hebben."@nl ;
        owl:onProperty dct:modified ;
        owl:someValuesFrom xsd:date ;
        owl:minCardinality "0"^^xsd:nonNegativeInteger ;
        owl:maxCardinality "1"^^xsd:nonNegativeInteger
    ] ;
    rdfs:subClassOf [ a owl:Restriction ;
        rdfs:comment "Een aangifte heeft een status."@nl ;
        # Codelijst: https://github.com/milieuinfo/codelijst-rie-iepr/blob/main/src/source/aangifte_status.csv
        owl:onProperty adms:status ;
        owl:someValuesFrom adms:Status ;
        owl:minCardinality "1"^^xsd:nonNegativeInteger ;
        owl:maxCardinality "1"^^xsd:nonNegativeInteger
    ] .

:Aangifte a owl:Class ;
    rdfs:label "Aangifte"@nl ;
    rdfs:comment "Een aangifte is een document dat wordt ingediend bij de overheid."@nl ;
    hydra:search [ a hydra:IriTemplate ;
        hydra:template "https://data.mjv.omgeving.vlaanderen.be/id/aangifte/{vlaanderenId}"^^hydra:Rfc6570Template ;
        hydra:mapping [ hydra:variable "vlaanderenId" ; hydra:property :vlaanderenId ; hydra:required true ]
    ] ;
    rdfs:subClassOf dossier:Stuk ;
    rdfs:subClassOf [ a owl:Restriction ;
        rdfs:comment "Een aangifte heeft betrekking tot een enkele exploitatie."@nl ;
        owl:onProperty dct:subject ;
        owl:onClass :Exploitatie ;
        owl:qualifiedCardinality "1"^^xsd:nonNegativeInteger
    ] ;
    rdfs:subClassOf [ a owl:Restriction ;
        rdfs:comment "Een aangifte heeft een datum van indiening."@nl ;
        owl:onProperty dct:created ;
        owl:someValuesFrom xsd:date ;
        owl:minCardinality "1"^^xsd:nonNegativeInteger ;
        owl:maxCardinality "1"^^xsd:nonNegativeInteger
    ] ;
    rdfs:subClassOf [ a owl:Restriction ;
        rdfs:comment "Een aangifte kan een datum van goedkeuring hebben."@nl ;
        owl:onProperty dct:modified ;
        owl:someValuesFrom xsd:date ;
        owl:minCardinality "0"^^xsd:nonNegativeInteger ;
        owl:maxCardinality "1"^^xsd:nonNegativeInteger
    ] ;
    rdfs:subClassOf [ a owl:Restriction ;
        rdfs:comment "Een aangifte kan deel zijn van een andere bundel."@nl ;
        owl:onProperty dct:isPartOf ;
        owl:someValuesFrom :Aangiftebundel ;
        owl:minCardinality "0"^^xsd:nonNegativeInteger ;
        owl:maxCardinality "1"^^xsd:nonNegativeInteger
    ] ;
    rdfs:subClassOf [ a owl:Restriction ;
        rdfs:comment "Een aangifte heeft een informatie classificatie."@nl ;
        owl:onProperty dossier:informatieclassificatie ;
        owl:minCardinality "0"^^xsd:nonNegativeInteger ;
        owl:maxCardinality "1"^^xsd:nonNegativeInteger
    ] .

# --------------------------------------- #
# Object Properties
# --------------------------------------- #
# Object properties worden vermeden waar mogelijk
# Business benamingen worden in concepten vastgelegd

:rubriek a owl:ObjectProperty ;
    rdfs:label "Rubriek"@nl ;
    rdfs:comment "De rubriek die van toepassing is op een proces of installatie."@nl ;
    rdfs:domain :Proces ;
    rdfs:range :Rubriek .

:parameter a owl:ObjectProperty ;
    rdfs:label "Parameter"@nl ;
    rdfs:comment "De parameter die wordt gebruikt bij een eigenschap of meting."@nl ;
    rdfs:domain :Systeemeigenschap ;
    rdfs:range pplan:Variable .

:datatype a owl:ObjectProperty ;
    rdfs:label "Datatype"@nl ;
    rdfs:comment "Het datatype van de waarde van een systeem eigenschap."@nl ;
    rdfs:domain :Systeemeigenschap ;
    rdfs:range rdfs:Datatype .

:aangifte a owl:ObjectProperty ;
    rdfs:label "Aangifte"@nl ;
    rdfs:comment "De aangifte die gerelateerd is aan een exploitatielocatie of observatie."@nl ;
    rdfs:range :Aangifte .

# --------------------------------------- #
# Data Properties
# --------------------------------------- #

:localId a owl:DatatypeProperty ;
    rdfs:label "Local Identifier"@en ;
    rdfs:comment "Een local identifier is een unieke identificatie binnen de context van RIE-IEPR."@en ;
    rdfs:range xsd:string .

:vlaanderenId a owl:DatatypeProperty ;
    rdfs:label "Vlaanderen Identifier"@nl ;
    rdfs:comment "Een unieke identificatie binnen de context van Vlaanderen, gebruikt voor het identificeren van entiteiten zoals aangiften."@nl ;
    rdfs:range xsd:string .

:inspireId a owl:DatatypeProperty ;
    rdfs:label "INSPIRE Identifier"@en ;
    rdfs:comment "Een INSPIRE Identifier is een unieke identificatie conform de INSPIRE specificaties, gebruikt voor het identificeren van geografische entiteiten."@en ;
    rdfs:range xsd:string .

:notatietype a owl:DatatypeProperty ;
    rdfs:label "Notatietype"@nl ;
    rdfs:comment "Het datatype-IRI van een skos:notation typed literal, opgeslagen als URI-string zodat het datatype en de notatie-waarde afzonderlijk bewaard worden."@nl ;
    rdfs:domain adms:Identifier ;
    rdfs:range xsd:anyURI .

:inGebruikVanaf a owl:DatatypeProperty ;
    rdfs:label "in gebruik vanaf"@nl ;
    rdfs:comment "De niet-functionele datum waarop een entiteit in gebruik is genomen."@nl ;
    rdfs:range xsd:date .

:inGebruikTot a owl:DatatypeProperty ;
    rdfs:label "in gebruik tot"@nl ;
    rdfs:comment "De niet-functionele datum waarop een entiteit buiten gebruik is gesteld."@nl ;
    rdfs:range xsd:date .

# Expliciete restricties op adms:Identifier voor notatie en notatie-datatype (M5)
adms:Identifier rdfs:subClassOf [ a owl:Restriction ;
    rdfs:comment "Een externe identificator heeft een notatie waarde"@nl ;
    owl:onProperty skos:notation ;
    owl:minCardinality "0"^^xsd:nonNegativeInteger ;
    owl:maxCardinality "1"^^xsd:nonNegativeInteger
] ;
rdfs:subClassOf [ a owl:Restriction ;
    rdfs:comment "Een externe identificator heeft een notatie type (het datatype-IRI van de skos:notation typed literal)"@nl ;
    owl:onProperty :notatietype ;
    owl:someValuesFrom xsd:anyURI ;
    owl:minCardinality "0"^^xsd:nonNegativeInteger ;
    owl:maxCardinality "1"^^xsd:nonNegativeInteger
] .

# Expliciete restricties op locn:Address voor ontbrekende adresvelden (M6)
locn:Address rdfs:subClassOf [ a owl:Restriction ;
    rdfs:comment "Een adres kan een volledig adres hebben als vrije tekst"@nl ;
    owl:onProperty locn:fullAddress ;
    owl:someValuesFrom xsd:string ;
    owl:minCardinality "0"^^xsd:nonNegativeInteger ;
    owl:maxCardinality "1"^^xsd:nonNegativeInteger
] ;
rdfs:subClassOf [ a owl:Restriction ;
    rdfs:comment "Een adres kan een huisnummer of locatieaanduiding hebben"@nl ;
    owl:onProperty locn:locatorDesignator ;
    owl:someValuesFrom xsd:string ;
    owl:minCardinality "0"^^xsd:nonNegativeInteger ;
    owl:maxCardinality "1"^^xsd:nonNegativeInteger
] .

# Proces Procedures. Deze zijn overgenomen van de codelijsten en worden hier hard gecodeerd als concepten omdat deze business logica bevatten.
:verwerkingProcedure a sosa:Procedure, skos:Concept ;
    rdfs:label "Verwerkingsprocedure"@nl ;
    rdfs:comment "Een verwerkingsprocedure is een specifieke procedure die betrekking heeft op de verwerking van stoffen binnen een proces."@nl ;
    skos:related <https://data.omgeving.vlaanderen.be/id/concept/riepr/procedure-type/verwerking> .
:onttrekkingProcedure a sosa:Procedure, skos:Concept ;
    rdfs:label "Onttrekkingprocedure"@nl ;
    rdfs:comment "Een onttrekkingsprocedure is een specifieke procedure die betrekking heeft op het transport van grondstoffen binnen een proces."@nl ;
    skos:related <https://data.omgeving.vlaanderen.be/id/concept/riepr/procedure-type/onttrekking> .
:emissieProcedure a sosa:Procedure, skos:Concept ;
    rdfs:label "Emissieprocedure"@nl ;
    rdfs:comment "Een emissieprocedure is een specifieke procedure die betrekking heeft op het uitstoten of lozen van stoffen aan emissiepunten."@nl ;
    skos:related <https://data.omgeving.vlaanderen.be/id/concept/riepr/procedure-type/emissie> .
:meetProcedure a sosa:Procedure, skos:Concept ;
    rdfs:label "Meetprocedure"@nl ;
    rdfs:comment "Een meetprocedure is een specifieke procedure die wordt gebruikt om metingen uit te voeren op meetpunten."@nl ;
    skos:related <https://data.omgeving.vlaanderen.be/id/concept/riepr/procedure-type/meet> .
:uitwisselProcedure a sosa:Procedure, skos:Concept ;
    rdfs:label "Uitwisselprocedure"@nl ;
    rdfs:comment "Een uitwisselprocedure is een specifieke procedure die betrekking heeft op het uitwisselen van stoffen tussen processen."@nl ;
    skos:related <https://data.omgeving.vlaanderen.be/id/concept/riepr/procedure-type/uitwissel> .

# Status types. Deze zijn overgenomen van de codelijsten en worden hier hard gecodeerd als concepten omdat deze business logica bevatten.
:inGebruik a adms:Status, skos:Concept ;
    rdfs:label "In gebruik"@nl ;
    rdfs:comment "De entiteit is in gebruik."@nl ;
    skos:related <https://data.omgeving.vlaanderen.be/id/concept/riepr/status-type/in-gebruik> .
:ontmanteld a adms:Status, skos:Concept ;
    rdfs:label "Ontmanteld"@nl ;
    rdfs:comment "De entiteit is ontmanteld."@nl ;
    skos:related <https://data.omgeving.vlaanderen.be/id/concept/riepr/status-type/ontmanteld> .

# --------------------------------------- #
# Axioms
# --------------------------------------- #
[ a owl:Class ;
    rdfs:comment "Een proces met een emissie procedure type als dct:type moet stoffen uitstoten of lozen aan een emissiepunt"@nl ;
    owl:intersectionOf ( :Proces [ a owl:Restriction ;
        owl:onProperty dct:type ;
        owl:someValuesFrom <https://data.omgeving.vlaanderen.be/id/concept/riepr/procedure-type/emissie>
    ] ) ;
] rdfs:subClassOf [ a owl:Restriction ;
    owl:onProperty ssn:implementedBy ;
    owl:someValuesFrom :Emissiepunt
] .

[ a owl:Class ;
    rdfs:comment "Een proces met een onttrekking procedure type als dct:type moet grondstoffen winnen of bemonsteren aan een onttrekkingspunt"@nl ;
    owl:intersectionOf ( :Proces [ a owl:Restriction ;
        owl:onProperty dct:type ;
        owl:someValuesFrom <https://data.omgeving.vlaanderen.be/id/concept/riepr/procedure-type/onttrekking>
    ] ) ;
] rdfs:subClassOf [ a owl:Restriction ;
    owl:onProperty ssn:implementedBy ;
    owl:someValuesFrom :Onttrekkingspunt
] .

[ a owl:Class ;
    rdfs:comment "Een proces met een verwerkingsprocedure type als dct:type moet een installatie implementeren"@nl ;
    owl:intersectionOf ( :Proces [ a owl:Restriction ;
        owl:onProperty dct:type ;
        owl:someValuesFrom <https://data.omgeving.vlaanderen.be/id/concept/riepr/procedure-type/verwerking>
    ] ) ;
] rdfs:subClassOf [ a owl:Restriction ;
    owl:onProperty ssn:implementedBy ;
    owl:someValuesFrom :Installatie
] .

[ a owl:Class ;
    rdfs:comment "Een proces met een meetprocedure type als dct:type moet een meetpunt implementeren"@nl ;
    owl:intersectionOf ( :Proces [ a owl:Restriction ;
        owl:onProperty dct:type ;
        owl:someValuesFrom <https://data.omgeving.vlaanderen.be/id/concept/riepr/procedure-type/meet>
    ] ) ;
] rdfs:subClassOf [ a owl:Restriction ;
    owl:onProperty ssn:implementedBy ;
    owl:someValuesFrom :Meetpunt
] .

[ a owl:Class ;
    rdfs:comment "Een proces met een uitwisselprocedure type als dct:type moet een uitwisselpunt implementeren"@nl ;
    owl:intersectionOf ( :Proces [ a owl:Restriction ;
        owl:onProperty dct:type ;
        owl:someValuesFrom <https://data.omgeving.vlaanderen.be/id/concept/riepr/procedure-type/uitwissel>
    ] ) ;
] rdfs:subClassOf [ a owl:Restriction ;
    owl:onProperty ssn:implementedBy ;
    owl:someValuesFrom :Uitwisselpunt
] .

[ a owl:Class ;
    rdfs:comment "Een proces met een hoofdactiviteit type als dct:type moet een exploitatie implementeren"@nl ;
    owl:intersectionOf ( :Proces [ a owl:Restriction ;
        owl:onProperty dct:type ;
        owl:someValuesFrom <https://data.omgeving.vlaanderen.be/id/concept/riepr/hoofdactiviteit-type>
    ] ) ;
] rdfs:subClassOf [ a owl:Restriction ;
    owl:onProperty ssn:implementedBy ;
    owl:someValuesFrom :Exploitatie
] .

# p-plan does not have an inverse indication for pplan:hasOutputVar
# It does have an inverse for hasInputVar
pplan:isOutputVarOf owl:inverseOf pplan:hasOutputVar .
