    rdfs:subClassOf [ a owl:Restriction ;
        rdfs:comment "Een meetpunt moet een benaming hebben"@nl ;
        owl:onProperty rdfs:label ;
        owl:minCardinality "1"^^xsd:nonNegativeInteger
    ] ;
    rdfs:subClassOf [ a owl:Restriction ;
        rdfs:comment "Een meetpunt kan meerdere eigenschappen hebben"@nl ;
        owl:onProperty ssn:hasProperty ;
        owl:someValuesFrom :Systeemeigenschap ;
