    rdfs:subClassOf [ a owl:Restriction ;
        # *..* relation with the inverse of ssn:hasSubSystem
        rdfs:comment "Een meetpunt kan filters hebben"@nl ;
        owl:onProperty ssn:hasSubSystem ;
        owl:someValuesFrom :Filter ;
        owl:minCardinality "0"^^xsd:nonNegativeInteger
    ] ;
    rdfs:subClassOf [ a owl:Restriction ;
        rdfs:comment "Een meetpunt kan een datum in gebruik tot hebben"@nl ;
        owl:onProperty :inGebruikTot ;
        owl:someValuesFrom xsd:date ;
        owl:minCardinality "0"^^xsd:nonNegativeInteger ;
        owl:maxCardinality "1"^^xsd:nonNegativeInteger
