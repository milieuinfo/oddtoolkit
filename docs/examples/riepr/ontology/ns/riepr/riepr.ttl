        owl:maxCardinality "1"^^xsd:nonNegativeInteger
    ] ;
    rdfs:subClassOf [ a owl:Restriction ;
        rdfs:comment "Een uitwisselpunt moet een geldigheid start hebben"@nl ;
        owl:onProperty dct:issued ;
        owl:someValuesFrom xsd:date ;
        owl:minCardinality "1"^^xsd:nonNegativeInteger ;
        owl:maxCardinality "1"^^xsd:nonNegativeInteger
    ] ;
    rdfs:subClassOf [ a owl:Restriction ;
        rdfs:comment "Een uitwisselpunt kan een geldigheid einde hebben"@nl ;
        owl:onProperty dct:valid ;
        owl:someValuesFrom xsd:date ;
        owl:minCardinality "0"^^xsd:nonNegativeInteger ;
        owl:maxCardinality "1"^^xsd:nonNegativeInteger
    ] ;
    rdfs:subClassOf [ a owl:Restriction ;
        rdfs:comment "Een uitwisselpunt kan verbonden zijn aan een enkele aangifte"@nl ;
        owl:onProperty :aangifte ;
        owl:someValuesFrom :Aangifte ;
