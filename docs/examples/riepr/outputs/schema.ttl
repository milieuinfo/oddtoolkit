@prefix ssn-system: <http://www.w3.org/ns/ssn/systems/> .
@prefix vann:       <http://purl.org/vocab/vann/> .
@prefix xsd:        <http://www.w3.org/2001/XMLSchema#> .

:ExploitatieShape  rdf:type  sh:NodeShape;
        sh:property     [ sh:datatype     xsd:date;
                          sh:description  "Een exploitatie moet een geldigheid start hebben"@nl;
                          sh:maxCount     "1"^^xsd:int;
                          sh:minCount     "1"^^xsd:int;
                          sh:path         dct:issued
                        ];
        sh:property     [ sh:description  "Een exploitatie moet een benaming hebben"@nl;
                          sh:minCount     "1"^^xsd:int;
                          sh:path         rdfs:label
                        ];
        sh:property     [ sh:class        :Contactpersoon;
                          sh:description  "Een exploitatie kan meerdere contactpersonen hebben"@nl;
                          sh:minCount     "0"^^xsd:int;
                          sh:path         org:hasMember
                        ];
        sh:property     [ sh:class        adms:Status;
                          sh:description  "Een exploitatie heeft een status"@nl;
                          sh:maxCount     "1"^^xsd:int;
                          sh:minCount     "1"^^xsd:int;
                          sh:path         adms:status
                        ];
        sh:property     [ sh:datatype     xsd:date;
                          sh:description  "Een exploitatie kan een geldigheid einde hebben"@nl;
                          sh:maxCount     "1"^^xsd:int;
                          sh:minCount     "0"^^xsd:int;
                          sh:path         dct:valid
                        ];
        sh:property     [ sh:class        :Aangifte;
                          sh:description  "Een exploitatie kan verbonden zijn aan een enkele aangifte"@nl;
                          sh:maxCount     "1"^^xsd:int;
                          sh:minCount     "0"^^xsd:int;
                          sh:path         :aangifte
                        ];
        sh:property     [ sh:class        adms:Identifier;
                          sh:description  "Een exploitatie kan externe identificaties hebben (optioneel)"@nl;
                          sh:minCount     "0"^^xsd:int;
                          sh:path         adms:identifier
                        ];
        sh:property     [ sh:class        :Exploitatielocatie;
                          sh:description  "Een exploitatie wordt op een bepaalde exploitatie locatie uitgevoerd"@nl;
                          sh:maxCount     "1"^^xsd:int;
                          sh:minCount     "1"^^xsd:int;
                          sh:path         ssn:deployedOnPlatform
                        ];
        sh:property     [ sh:class        ssn:System;
                          sh:description  "Een exploitatie zet systemem in"@nl;
                          sh:minCount     "0"^^xsd:int;
                          sh:path         ssn:deployedSystem
                        ];
        sh:property     [ sh:datatype     xsd:dateTime;
                          sh:description  "Een exploitatie moet een modificatie datum hebben"@nl;
                          sh:maxCount     "1"^^xsd:int;
                          sh:minCount     "1"^^xsd:int;
                          sh:path         dct:modified
                        ];
        sh:property     [ sh:datatype     xsd:dateTime;
                          sh:description  "Een exploitatie moet een creatie datum hebben"@nl;
                          sh:maxCount     "1"^^xsd:int;
                          sh:minCount     "1"^^xsd:int;
                          sh:path         dct:created
                        ];
        sh:property     [ sh:class        :Proces;
                          sh:description  "Een exploitatie implementeert een proces"@nl;
                          sh:maxCount     "1"^^xsd:int;
                          sh:minCount     "1"^^xsd:int;
                          sh:path         ssn:implements
                        ];
        sh:targetClass  :Exploitatie .

:RubriekShape  rdf:type  sh:NodeShape;
        sh:property     [ sh:description  "Een rubriek moet een code hebben"@nl;
                          sh:maxCount     "1"^^xsd:int;
                          sh:minCount     "1"^^xsd:int;
                          sh:path         skos:notation
                        ];
        sh:property     [ sh:description  "Een rubriek kan een beschrijving hebben"@nl;
                          sh:maxCount     "1"^^xsd:int;
                          sh:minCount     "0"^^xsd:int;
                          sh:path         skos:definition
                        ];
        sh:property     [ sh:description  "Een rubriek kan een typering hebben via dct:type"@nl;
                          sh:maxCount     "1"^^xsd:int;
                          sh:minCount     "1"^^xsd:int;
                          sh:path         dct:type
                        ];
        sh:targetClass  :Rubriek .

:OnttrekkingProcedureShape
        rdf:type        sh:NodeShape;
        sh:targetClass  :OnttrekkingProcedure .

:AbstractEmissiepuntShape
        rdf:type        sh:NodeShape;
        sh:targetClass  :AbstractEmissiepunt .

:TransportProcedureShape
        rdf:type        sh:NodeShape;
        sh:targetClass  :TransportProcedure .

:ContactpersoonShape  rdf:type  sh:NodeShape;
        sh:property     [ sh:datatype     xsd:dateTime;
                          sh:description  "Een exploitant contactpersoon kan een creatie datum hebben"@nl;
                          sh:maxCount     "1"^^xsd:int;
                          sh:minCount     "0"^^xsd:int;
                          sh:path         dct:created
                        ];
        sh:property     [ sh:description  "Een exploitant contactpersoon kan een e-mailadres hebben"@nl;
                          sh:maxCount     "1"^^xsd:int;
                          sh:minCount     "0"^^xsd:int;
                          sh:path         foaf:mbox
                        ];
        sh:property     [ sh:description  "Een exploitant contactpersoon kan een telefoonnummer hebben"@nl;
                          sh:maxCount     "1"^^xsd:int;
                          sh:minCount     "0"^^xsd:int;
                          sh:path         foaf:phone
                        ];
        sh:property     [ sh:datatype     xsd:dateTime;
                          sh:description  "Een exploitant contactpersoon kan een modificatie datum hebben"@nl;
                          sh:maxCount     "1"^^xsd:int;
                          sh:minCount     "0"^^xsd:int;
                          sh:path         dct:modified
                        ];
        sh:property     [ sh:class     :Exploitatie;
                          sh:minCount  "0"^^xsd:int;
                          sh:path      org:memberOf
                        ];
        sh:property     [ sh:description  "Een exploitant contactpersoon moet een naam hebben"@nl;
                          sh:minCount     "1"^^xsd:int;
                          sh:path         foaf:name
                        ];
        sh:property     [ sh:description  "Een exploitant contactpersoon moet een benaming hebben"@nl;
                          sh:minCount     "1"^^xsd:int;
                          sh:path         rdfs:label
                        ];
        sh:property     [ sh:datatype     xsd:date;
                          sh:description  "Een exploitant contactpersoon kan een geldigheid einde hebben"@nl;
                          sh:maxCount     "1"^^xsd:int;
                          sh:minCount     "0"^^xsd:int;
                          sh:path         dct:valid
                        ];
        sh:property     [ sh:description  "Een exploitant contactpersoon moet een functie hebben binnen de organisatie"@nl;
                          sh:maxCount     "1"^^xsd:int;
                          sh:minCount     "0"^^xsd:int;
                          sh:path         org:hasRole
                        ];
        sh:property     [ sh:datatype     xsd:date;
                          sh:description  "Een exploitant contactpersoon kan een geldigheid start hebben"@nl;
                          sh:maxCount     "1"^^xsd:int;
                          sh:minCount     "0"^^xsd:int;
                          sh:path         dct:issued
                        ];
        sh:property     [ sh:description  "Een exploitant contactpersoon kan een opmerking hebben"@nl;
                          sh:minCount     "0"^^xsd:int;
                          sh:path         rdfs:comment
                        ];
        sh:targetClass  :Contactpersoon .

:AangifteShape  rdf:type  sh:NodeShape;
        sh:property     [ sh:description  "Een aangifte heeft een informatie classificatie."@nl;
                          sh:maxCount     "1"^^xsd:int;
                          sh:minCount     "0"^^xsd:int;
                          sh:path         dossier:informatieclassificatie
                        ];
        sh:property     [ sh:description  "Een aangifte heeft optioneel een auteur (die verschillend kan zijn dan de indiener)."@nl;
                          sh:maxCount     "1"^^xsd:int;
                          sh:minCount     "0"^^xsd:int;
                          sh:path         prov:wasAssociatedWith
                        ];
        sh:property     [ sh:class        :Aangifte;
                          sh:description  "Een aangifte kan deel zijn van een andere aangifte."@nl;
                          sh:maxCount     "1"^^xsd:int;
                          sh:minCount     "0"^^xsd:int;
                          sh:path         dct:isPartOf
                        ];
        sh:property     [ sh:datatype     xsd:date;
                          sh:description  "Een aangifte heeft een datum van indiening."@nl;
                          sh:maxCount     "1"^^xsd:int;
                          sh:minCount     "1"^^xsd:int;
                          sh:path         dct:created
                        ];
        sh:targetClass  :Aangifte .

:MeetProcedureShape  rdf:type  sh:NodeShape;
        sh:targetClass  :MeetProcedure .

:EmissieProcedureShape
        rdf:type        sh:NodeShape;
        sh:targetClass  :EmissieProcedure .

